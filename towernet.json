{
  "name": "towernet",
  "version": "3.0",
  "description": "TowerNet Communications — public US wireless carrier dataset spanning 24 months (May 2024 - May 2026) with 50 named towers across 11 cluster groupings, 8 plan tiers, and a hidden story: tower cluster SE-CLUSTER-A (containing problem tower SE-447 in Georgia/Alabama/Tennessee region) had 14 outages in 8 months vs system average 1.2/cluster. Subscribers near SE-447 churn at 6.2% vs 1.9% elsewhere.",
  "_meta": {
    "purpose": "RealityDB Atelier Module 4 (TowerNet) — Chief Revenue Officer root-cause investigation; HireSQL telecom assessments; SimLab churn analytics scenarios",
    "version": "1.0",
    "created": "2026-05-17",
    "author": "Eddy Mkwambe / Mpingo Systems",
    "scale_target": "50,000 rows across 24-month window May 2024 - May 2026",
    "currency": "USD (integer cents for all money fields; e.g., 1500 = $15.00)",
    "company": {
      "name": "TowerNet Communications",
      "stage": "Public company",
      "revenue_usd": 2800000000,
      "subscribers_total": 4200000,
      "trigger_event": "Board flagged subscriber growth stalled and ARPU declining in Q3; churn jumped from 2.1% to 3.8% in one region; root cause needed before investor call"
    },
    "story": {
      "summary": "Tower SE-447 (within SE-CLUSTER-A in the Southeast region: Georgia, Alabama, Tennessee) had 14 network outages over 8 months vs system average 1.2 outages per cluster. Subscribers in the SE-447 service area churn at 6.2% vs 1.9% across the rest of the network. Support ticket volume mentioning network quality is 3x higher near SE-447. The maintenance backlog on this cluster was known internally but never escalated.",
      "smoking_gun": "SE-447 incident frequency (14 in 8 months) + churn rate (6.2% vs 1.9%) + support ticket concentration (3x) + uptime 94.1% vs 99.7% — all visible together when stratified by tower_code (SE-447) or cluster_id (SE-CLUSTER-A).",
      "visibility_tiers": [
        "Surface (Ex 1-3): Overall churn 2.1% (GSMA benchmark); churn by region reveals Southeast outlier; churn by plan type rules out plan-mix as cause",
        "Investigation (Ex 4-7): 8-month time split reveals churn inflection; network_incidents by tower reveals SE-447 outlier (14 vs avg 1.2); support tickets near SE-447 confirm network-quality narrative; churned subscribers cite network issues",
        "Root cause (Ex 8-10): Revenue at risk calculation ($1.58M ARR); SE-447 incident+churn correlation; scenario quantification (emergency maintenance $2.1M vs retention credits $1.8M)"
      ],
      "enforcement": "Baseline distributions are written into this pack with UNIFORM behavior across all 50 towers and 8 plans. The SE-447 concentration story (14 incidents in 8 months, 6.2% local churn, 3x support tickets, 94.1% uptime, critical_backlog maintenance status) is enforced post-generation by scripts/enforce-towernet-story.mjs (Stage 7). The enforcer's T0-T6 transformations target SE-447 via towers.tower_code='SE-447'. Filter must use tower_code (bounded to 50 declared values) because the engine generates ~6 tower rows per declared tower_code."
    },
    "exceptions": [
      {
        "rule": "Tower count should be exactly 50, plans count 8 (one per named value)",
        "actual": "~125 tower rows and ~125 plan rows at 50K scale (engine sizes roots by cascade math, not by explicit fixed counts)",
        "reason": "Engine has no per-table row-count override. Story-critical filtering uses towers.tower_code (bounded to 50 declared values) and towers.cluster_id (bounded to 11 declared values) instead of id columns.",
        "approved_by": "Eddy Mkwambe",
        "date": "2026-05-17",
        "future_fix": "Engine v2 feature request: support fixed lookup tables. Same gap noted in MedCore, SupplyLink packs."
      },
      {
        "rule": "Lesson 2: avoid created_at on event tables (would conflict with explicit event timestamps)",
        "actual": "created_at present on ALL tables per spec contract; conflicts expected with subscriptions.started_at, invoices.issued_at, payments.processed_at, network_incidents.started_at, support_tickets.opened_at, churn_signals.detected_at, usage_records.record_date",
        "reason": "Spec contract explicitly requires created_at on every table. Baseline temporal_logic will score ~50/100. Stage 7 enforcer transformation T6 explicitly fixes temporal ordering post-generation. Final assess after enforcement should reach 100. DELIBERATE LESSON 2 OVERRIDE for spec fidelity.",
        "approved_by": "Eddy Mkwambe",
        "date": "2026-05-17"
      },
      {
        "rule": "Scale confidence target HIGH",
        "actual": "Expected MEDIUM at 50K (~250 root rows across 2 root tables, matches SupplyLink pattern)",
        "reason": "Cascade math for 11 tables with 50K budget. HIGH confidence requires ~250K total rows. Accepting MEDIUM for v1.0 baseline."
      },
      {
        "rule": "Distribution diversity should be 100",
        "actual": "Expected ~88-92 — same domain-ratio issue as prior packs",
        "reason": "Inherent ratios like uptime_pct_ytd near 99.7%, payment status 92% succeeded, plan_type 35/55/10 will flag as 'skewed' but reflect industry reality."
      }
    ],
    "open_questions": [
      "support_tickets.subject uses 'sentence' strategy — verify engine supports this strategy or fall back to enum/text placeholder.",
      "Money fields use integer cents (1500 = $15.00). Downstream tooling must handle the cents convention.",
      "tower_code SE-447 has equal weight (2%) to other tower codes; the enforcer adds the story concentration.",
      "Roaming currency variations not modeled in v1.0 — invoice.amount_cents is USD only."
    ],
    "citations": [
      {
        "field": "Monthly churn rate baseline 2.1%",
        "claim": "GSMA reports US wireless monthly churn averaging 2-3%; 2.1% as midpoint",
        "source": "GSMA Mobile Economy Report 2024",
        "url": "https://www.gsma.com/mobileeconomy"
      },
      {
        "field": "Network uptime 99.7% system-wide benchmark",
        "claim": "Ericsson and industry benchmarks for healthy mobile network uptime at 99.5-99.9%",
        "source": "Ericsson Mobility Report 2024",
        "url": "https://www.ericsson.com/mobility-report"
      },
      {
        "field": "ARPU $45 blended baseline",
        "claim": "US wireless ARPU $40-$55 depending on plan mix; $45 represents postpaid-weighted blended",
        "source": "ITU World Telecommunication Statistics 2024",
        "url": "https://www.itu.int/itu-d/statistics"
      },
      {
        "field": "Churn-network quality correlation",
        "claim": "J.D. Power finds network quality issues account for 30-40% of stated churn reasons",
        "source": "J.D. Power Wireless Customer Satisfaction Study 2024",
        "url": "https://www.jdpower.com/business/resources/wireless-customer-satisfaction"
      },
      {
        "field": "Tower maintenance cost benchmarks",
        "claim": "Industry benchmarks for tower cluster maintenance and capex amortization",
        "source": "TOWERCOS / TowerXchange Annual Report 2024",
        "url": "https://www.towerxchange.com"
      },
      {
        "field": "Plan mix (prepaid 35%, postpaid 55%, business 10%)",
        "claim": "Approximate US wireless plan distribution; postpaid-dominant",
        "source": "Industry consensus from FCC and major-carrier 10-K filings",
        "url": "https://www.fcc.gov/wireless-telecommunications"
      },
      {
        "field": "Support ticket categorization patterns",
        "claim": "Illustrative based on telecom customer service operations",
        "source": "Illustrative — supported by industry context",
        "url": "https://realitydb.dev/docs"
      },
      {
        "field": "Network incident rate (~1.2 per cluster baseline)",
        "claim": "Illustrative within plausible range for regional tower clusters",
        "source": "Illustrative — supported by Ericsson context",
        "url": "https://realitydb.dev/docs"
      }
    ]
  },

