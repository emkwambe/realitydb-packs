{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "restaurants": {
      "match": "restaurants",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "company_name"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "open",
              "closed",
              "busy"
            ],
            "weights": [
              70,
              20,
              10
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "menus": {
      "match": "menus",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "restaurant_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "restaurants",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "menu_items": {
      "match": "menu_items",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "menu_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "menus",
            "column": "id"
          }
        },
        "price": {
          "strategy": "float",
          "options": {
            "min": 5,
            "max": 50
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "customers": {
      "match": "customers",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "email": {
          "strategy": "email"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "marketing_campaigns": {
      "match": "marketing_campaigns",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "channel": {
          "strategy": "enum",
          "options": {
            "values": [
              "email",
              "social",
              "push"
            ],
            "weights": [
              50,
              30,
              20
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "coupons": {
      "match": "coupons",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "campaign_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "marketing_campaigns",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "orders": {
      "match": "orders",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "restaurant_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "restaurants",
            "column": "id"
          }
        },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "customers",
            "column": "id"
          }
        },
        "coupon_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "coupons",
            "column": "id"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "delivered",
              "cancelled"
            ],
            "weights": [
              95,
              5
            ],
            "lifecycleRules": [
              {
                "value": "cancelled",
                "nullFields": [
                  "completed_at"
                ]
              }
            ]
          }
        },
        "completed_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "payments": {
      "match": "payments",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "order_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "orders",
            "column": "id"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "captured",
              "failed"
            ],
            "weights": [
              90,
              10
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "deliveries": {
      "match": "deliveries",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "order_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "orders",
            "column": "id"
          }
        },
        "vehicle": {
          "strategy": "enum",
          "options": {
            "values": [
              "bike",
              "car"
            ],
            "weights": [
              70,
              30
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "loyalty_accounts": {
      "match": "loyalty_accounts",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "customers",
            "column": "id"
          }
        },
        "tier": {
          "strategy": "enum",
          "options": {
            "values": [
              "silver",
              "gold"
            ],
            "weights": [
              80,
              20
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "subscriptions": {
      "match": "subscriptions",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "customers",
            "column": "id"
          }
        },
        "plan": {
          "strategy": "enum",
          "options": {
            "values": [
              "monthly",
              "annual"
            ],
            "weights": [
              90,
              10
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "referrals": {
      "match": "referrals",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "referrer_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "customers",
            "column": "id"
          }
        },
        "reward": {
          "strategy": "float",
          "options": {
            "min": 5,
            "max": 20
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "shift_logs": {
      "match": "shift_logs",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "restaurant_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "restaurants",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "reviews": {
      "match": "reviews",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "order_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "orders",
            "column": "id"
          }
        },
        "rating": {
          "strategy": "integer",
          "options": {
            "min": 1,
            "max": 5
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 42,
    "timelineDays": 365,
    "growthCurve": "s-curve",
    "anomalyRate": 0.05
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 42
    }
  }
}