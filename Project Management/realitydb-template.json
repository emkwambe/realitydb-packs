{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "teams": {
      "match": "teams",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "full_name"
        },
        "description": {
          "strategy": "text"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "members": {
      "match": "members",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "team_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "teams",
            "column": "id"
          }
        },
        "name": {
          "strategy": "full_name"
        },
        "email": {
          "strategy": "email"
        },
        "role": {
          "strategy": "enum",
          "options": {
            "values": [
              "admin",
              "member",
              "viewer"
            ],
            "weights": [
              10,
              70,
              20
            ]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "active",
              "suspended",
              "deactivated"
            ],
            "weights": [
              80,
              15,
              5
            ],
            "lifecycleRules": [
              {
                "value": "deactivated",
                "nullFields": [
                  "last_active_at"
                ]
              }
            ]
          }
        },
        "last_active_at": {
          "strategy": "timestamp"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "projects": {
      "match": "projects",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "team_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "teams",
            "column": "id"
          }
        },
        "name": {
          "strategy": "full_name"
        },
        "description": {
          "strategy": "text"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "planning",
              "active",
              "on_hold",
              "completed",
              "cancelled"
            ],
            "weights": [
              20,
              50,
              10,
              15,
              5
            ],
            "lifecycleRules": [
              {
                "value": "cancelled",
                "nullFields": [
                  "completed_at"
                ]
              }
            ]
          }
        },
        "completed_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "tasks": {
      "match": "tasks",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "project_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "projects",
            "column": "id"
          }
        },
        "assignee_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "members",
            "column": "id"
          }
        },
        "title": {
          "strategy": "full_name"
        },
        "description": {
          "strategy": "text"
        },
        "priority": {
          "strategy": "enum",
          "options": {
            "values": [
              "low",
              "medium",
              "high",
              "urgent"
            ],
            "weights": [
              25,
              40,
              25,
              10
            ]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "todo",
              "in_progress",
              "review",
              "done",
              "cancelled"
            ],
            "weights": [
              40,
              30,
              15,
              10,
              5
            ],
            "lifecycleRules": [
              {
                "value": "cancelled",
                "nullFields": [
                  "completed_at"
                ]
              }
            ]
          }
        },
        "completed_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "comments": {
      "match": "comments",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "task_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "tasks",
            "column": "id"
          }
        },
        "author_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "members",
            "column": "id"
          }
        },
        "content": {
          "strategy": "text"
        },
        "edited": {
          "strategy": "boolean"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "time_entries": {
      "match": "time_entries",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "task_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "tasks",
            "column": "id"
          }
        },
        "member_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "members",
            "column": "id"
          }
        },
        "hours": {
          "strategy": "float"
        },
        "entry_date": {
          "strategy": "timestamp"
        },
        "description": {
          "strategy": "text"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 123,
    "timelineDays": 180,
    "growthCurve": "s-curve",
    "anomalyRate": 0.08
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 123
    }
  }
}