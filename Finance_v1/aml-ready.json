      "match": "branches",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "branch_code": {
          "strategy": "template",
          "options": {
            "pattern": "BR-{{number}}",
            "min": 1000,
            "max": 9999
          }
        },
        "name": {
          "strategy": "template",
          "options": {
            "pattern": "{{firstName}} {{number}} Branch",
            "min": 1,
            "max": 99
          }
        },
        "city": {
          "strategy": "city"
        },
        "state": {
          "strategy": "state"
        },
        "zip_code": {
          "strategy": "zip_code"
        },
        "region": {
          "strategy": "enum",
          "options": {
            "values": [
              "Northeast",
              "Southeast",
              "Midwest",
              "Southwest",
              "West"
            ],
            "weights": [
              22,
              22,
              18,
              14,
              24
            ]
          }
        },
        "branch_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "full_service",
              "limited_service",
              "atm_only",
              "drive_thru"
