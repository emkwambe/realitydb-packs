          }
        },
        "opened_date": {
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 1,
            "maxYearsAgo": 30
          }
        },
        "is_active": {
          "strategy": "boolean",
          "options": {
            "trueWeight": 95
          }
        }
      }
    },
