{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "employees": {
      "match": "employees",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "clearance_level": {
          "strategy": "enum",
          "options": {
            "values": [
              "public",
              "internal",
              "confidential",
              "restricted"
            ],
            "weights": [
              10,
              70,
              15,
              5
            ]
          }
        },
        "department": {
          "strategy": "enum",
          "options": {
            "values": [
              "Engineering",
              "HR",
              "Sales",
              "Finance",
              "IT_Admin"
            ],
            "weights": [
              40,
              10,
              30,
              15,
              5
            ]
          }
        },
        "is_on_PIP": {
          "strategy": "boolean"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "devices": {
      "match": "devices",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "employee_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "employees",
            "column": "id"
          }
        },
        "os_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "Windows",
              "macOS",
              "Linux",
              "iOS"
            ],
            "weights": [
              65,
              20,
              10,
              5
            ]
          }
        },
        "is_managed": {
          "strategy": "boolean"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "authentication_logs": {
      "match": "authentication_logs",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "employee_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "employees",
            "column": "id"
          }
        },
        "result": {
          "strategy": "enum",
          "options": {
            "values": [
              "success",
              "fail",
              "mfa_challenge",
              "locked"
            ],
            "weights": [
              85,
              10,
              4,
              1
            ]
          }
        },
        "auth_method": {
          "strategy": "enum",
          "options": {
            "values": [
              "password",
              "sso",
              "biometric",
              "hardware_key"
            ],
            "weights": [
              40,
              45,
              10,
              5
            ]
          }
        },
        "ip_address": {
          "strategy": "string"
        },
        "timestamp": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "file_access_events": {
      "match": "file_access_events",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "employee_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "employees",
            "column": "id"
          }
        },
        "action": {
          "strategy": "enum",
          "options": {
            "values": [
              "read",
              "write",
              "delete",
              "download"
            ],
            "weights": [
              70,
              15,
              5,
              10
            ]
          }
        },
        "file_sensitivity": {
          "strategy": "enum",
          "options": {
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "weights": [
              50,
              30,
              15,
              5
            ]
          }
        },
        "occurred_at": {
          "strategy": "timestamp"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "network_traffic": {
      "match": "network_traffic",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "device_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "devices",
            "column": "id"
          }
        },
        "data_transferred_mb": {
          "strategy": "float"
        },
        "destination_category": {
          "strategy": "enum",
          "options": {
            "values": [
              "internal",
              "cloud_storage",
              "social_media",
              "unknown_dark_web"
            ],
            "weights": [
              80,
              15,
              4,
              1
            ]
          }
        },
        "timestamp": {
          "strategy": "timestamp"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "security_alerts": {
      "match": "security_alerts",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "type": {
          "strategy": "enum",
          "options": {
            "values": [
              "brute_force",
              "data_exfiltration",
              "impossible_travel",
              "unauthorized_access"
            ],
            "weights": [
              30,
              20,
              25,
              25
            ]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "open",
              "investigating",
              "resolved",
              "false_positive"
            ],
            "weights": [
              20,
              40,
              25,
              15
            ],
            "lifecycleRules": [
              {
                "value": "false_positive",
                "nullFields": [
                  "resolution_notes"
                ]
              }
            ]
          }
        },
        "severity": {
          "strategy": "enum",
          "options": {
            "values": [
              "informational",
              "low",
              "medium",
              "high",
              "critical"
            ],
            "weights": [
              40,
              30,
              15,
              10,
              5
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "incident_reports": {
      "match": "incident_reports",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "alert_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "security_alerts",
            "column": "id"
          }
        },
        "assigned_to": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "employees",
            "column": "id"
          }
        },
        "resolved_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 123,
    "timelineDays": 180,
    "growthCurve": "s-curve",
    "anomalyRate": 0.08
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 123
    }
  }
}