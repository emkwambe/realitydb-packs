{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "sensors": {
      "match": "sensors",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "sensor_id": {
          "strategy": "uuid"
        },
        "sensor_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "temperature",
              "vibration"
            ],
            "weights": [
              50,
              50
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "temperature_readings": {
      "match": "temperature_readings",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "temperature": {
          "strategy": "float"
        },
        "reading_time": {
          "strategy": "timestamp"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "normal",
              "overheating"
            ],
            "weights": [
              90,
              10
            ],
            "lifecycleRules": [
              {
                "value": "overheating",
                "nullFields": [
                  "completed_at"
                ]
              }
            ]
          }
        },
        "completed_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "reading_time",
            "dependencyRule": "after"
          }
        },
        "sensor_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensors",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "vibration_readings": {
      "match": "vibration_readings",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "vibration": {
          "strategy": "float"
        },
        "reading_time": {
          "strategy": "timestamp"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "normal",
              "excessive"
            ],
            "weights": [
              90,
              10
            ],
            "lifecycleRules": [
              {
                "value": "excessive",
                "nullFields": [
                  "completed_at"
                ]
              }
            ]
          }
        },
        "completed_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "reading_time",
            "dependencyRule": "after"
          }
        },
        "sensor_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensors",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "sensor_failures": {
      "match": "sensor_failures",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "failure_id": {
          "strategy": "uuid"
        },
        "failure_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "temperature_failure",
              "vibration_failure"
            ],
            "weights": [
              50,
              50
            ]
          }
        },
        "failure_time": {
          "strategy": "timestamp"
        },
        "resolved": {
          "strategy": "boolean"
        },
        "temperature_reading_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "temperature_readings",
            "column": "id"
          }
        },
        "vibration_reading_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "vibration_readings",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "maintenance_logs": {
      "match": "maintenance_logs",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "log_id": {
          "strategy": "uuid"
        },
        "maintenance_date": {
          "strategy": "timestamp"
        },
        "description": {
          "strategy": "string"
        },
        "performed_by": {
          "strategy": "string"
        },
        "failure_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensor_failures",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 42,
    "timelineDays": 365,
    "growthCurve": "s-curve",
    "anomalyRate": 0.05
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 42
    }
  }
}