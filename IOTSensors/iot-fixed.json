{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Converted from Studio v4 by realitydb doctor",
  "tables": {
    "sensors": {
      "match": "sensors",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "sensor_id": {
          "strategy": "uuid"
        },
        "sensor_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "temperature",
              "vibration"
            ],
            "weights": [
              50,
              50
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "temperature_readings": {
      "match": "temperature_readings",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "temperature": {
          "strategy": "decimal"
        },
        "reading_time": {
          "strategy": "past_date"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "normal",
              "overheating"
            ],
            "weights": [
              90,
              10
            ]
          }
        },
        "completed_at": {
          "strategy": "past_date"
        },
        "sensor_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensors",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "vibration_readings": {
      "match": "vibration_readings",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "vibration": {
          "strategy": "decimal"
        },
        "reading_time": {
          "strategy": "past_date"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "normal",
              "excessive"
            ],
            "weights": [
              90,
              10
            ]
          }
        },
        "completed_at": {
          "strategy": "past_date"
        },
        "sensor_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensors",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "sensor_failures": {
      "match": "sensor_failures",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "failure_id": {
          "strategy": "uuid"
        },
        "failure_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "temperature_failure",
              "vibration_failure"
            ],
            "weights": [
              50,
              50
            ]
          }
        },
        "failure_time": {
          "strategy": "past_date"
        },
        "resolved": {
          "strategy": "boolean"
        },
        "temperature_reading_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "temperature_readings",
            "column": "id"
          }
        },
        "vibration_reading_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "vibration_readings",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "maintenance_logs": {
      "match": "maintenance_logs",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "log_id": {
          "strategy": "uuid"
        },
        "maintenance_date": {
          "strategy": "past_date"
        },
        "description": {
          "strategy": "string"
        },
        "performed_by": {
          "strategy": "string"
        },
        "failure_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "sensor_failures",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    }
  }
}