{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Converted from Studio v4 by realitydb doctor",
  "tables": {
    "Patients": {
      "match": "Patients",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "string"
        },
        "date_of_birth": {
          "strategy": "past_date"
        },
        "gender": {
          "strategy": "enum",
          "options": {
            "values": [
              "male",
              "female",
              "other"
            ],
            "weights": [
              50,
              48,
              2
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Doctors": {
      "match": "Doctors",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "specialty": {
          "strategy": "string"
        },
        "license_number": {
          "strategy": "string"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Appointments": {
      "match": "Appointments",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "doctor_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Doctors",
            "column": "id"
          }
        },
        "appointment_date": {
          "strategy": "past_date"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "completed",
              "cancelled",
              "no_show"
            ],
            "weights": [
              73,
              21,
              6
            ]
          }
        },
        "completed_at": {
          "strategy": "past_date"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Prescriptions": {
      "match": "Prescriptions",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "medication_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Medications",
            "column": "id"
          }
        },
        "prescribed_at": {
          "strategy": "past_date"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "filled",
              "unfilled"
            ],
            "weights": [
              44,
              56
            ]
          }
        },
        "dispensed_at": {
          "strategy": "past_date"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Medications": {
      "match": "Medications",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "string"
        },
        "dosage": {
          "strategy": "string"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Pharmacy_Inventory": {
      "match": "Pharmacy_Inventory",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "medication_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Medications",
            "column": "id"
          }
        },
        "quantity": {
          "strategy": "integer"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Medical_Records": {
      "match": "Medical_Records",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "diagnosis": {
          "strategy": "string"
        },
        "test_results": {
          "strategy": "string"
        },
        "discharge_status": {
          "strategy": "enum",
          "options": {
            "values": [
              "routine",
              "other_care",
              "deceased"
            ],
            "weights": [
              74,
              25,
              1
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Lab_Tests": {
      "match": "Lab_Tests",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "test_type": {
          "strategy": "string"
        },
        "result": {
          "strategy": "enum",
          "options": {
            "values": [
              "normal",
              "abnormal"
            ],
            "weights": [
              95,
              5
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Billing_Invoices": {
      "match": "Billing_Invoices",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "amount": {
          "strategy": "decimal"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "paid",
              "unpaid"
            ],
            "weights": [
              60,
              40
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Insurance_Claims": {
      "match": "Insurance_Claims",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "patient_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Patients",
            "column": "id"
          }
        },
        "claim_amount": {
          "strategy": "decimal"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "approved",
              "denied"
            ],
            "weights": [
              81,
              19
            ]
          }
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Staff": {
      "match": "Staff",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "string"
        },
        "role": {
          "strategy": "string"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Departments": {
      "match": "Departments",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "string"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Hospital_Wards": {
      "match": "Hospital_Wards",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "department_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Departments",
            "column": "id"
          }
        },
        "bed_count": {
          "strategy": "integer"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    },
    "Shift_Schedules": {
      "match": "Shift_Schedules",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "staff_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "Staff",
            "column": "id"
          }
        },
        "shift_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "morning",
              "evening",
              "night"
            ],
            "weights": [
              52,
              36,
              12
            ]
          }
        },
        "shift_date": {
          "strategy": "past_date"
        },
        "created_at": {
          "strategy": "past_date"
        }
      }
    }
  }
}