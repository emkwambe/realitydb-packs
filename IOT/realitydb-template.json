{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "devices": {
      "match": "devices",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "device_name": {
          "strategy": "string"
        },
        "device_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "sensor",
              "actuator",
              "gateway"
            ],
            "weights": [
              50,
              30,
              20
            ]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "active",
              "inactive",
              "maintenance"
            ],
            "weights": [
              70,
              20,
              10
            ],
            "lifecycleRules": [
              {
                "value": "inactive",
                "nullFields": [
                  "last_active_at"
                ]
              }
            ]
          }
        },
        "owner_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "users",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "users": {
      "match": "users",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "username": {
          "strategy": "string"
        },
        "email": {
          "strategy": "email"
        },
        "role": {
          "strategy": "enum",
          "options": {
            "values": [
              "admin",
              "user",
              "guest"
            ],
            "weights": [
              20,
              70,
              10
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "readings": {
      "match": "readings",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "reading_value": {
          "strategy": "float"
        },
        "reading_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "temperature",
              "humidity",
              "pressure"
            ],
            "weights": [
              50,
              30,
              20
            ]
          }
        },
        "recorded_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "created_at",
            "dependencyRule": "after"
          }
        },
        "device_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "devices",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "alerts": {
      "match": "alerts",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "alert_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "warning",
              "critical",
              "info"
            ],
            "weights": [
              60,
              30,
              10
            ]
          }
        },
        "message": {
          "strategy": "string"
        },
        "triggered_at": {
          "strategy": "timestamp"
        },
        "reading_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "readings",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "locations": {
      "match": "locations",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "location_name": {
          "strategy": "string"
        },
        "latitude": {
          "strategy": "float"
        },
        "longitude": {
          "strategy": "float"
        },
        "device_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "devices",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "device_logs": {
      "match": "device_logs",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "log_message": {
          "strategy": "string"
        },
        "log_level": {
          "strategy": "enum",
          "options": {
            "values": [
              "info",
              "warning",
              "error"
            ],
            "weights": [
              50,
              30,
              20
            ]
          }
        },
        "logged_at": {
          "strategy": "timestamp"
        },
        "device_id": {
          "strategy": "uuid",
          "foreignKey": {
            "table": "devices",
            "column": "id"
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 123,
    "timelineDays": 180,
    "growthCurve": "s-curve",
    "anomalyRate": 0.08
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 123
    }
  }
}