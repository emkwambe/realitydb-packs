{
  "name": "financial-geo",
  "version": "1.0",
  "description": "Financial transactions with geographical positions (customers, merchants, fraud alerts). Includes lifecycle rules and temporal ordering.",
  "tables": {
    "customers": {
      "columns": {
        "customer_id": { "strategy": "uuid" },
        "full_name": { "strategy": "full_name" },
        "email": { "strategy": "email" },
        "phone": { "strategy": "phone" },
        "country": { "strategy": "enum", "options": { "values": ["US", "GB", "CA", "AU", "DE", "FR"], "weights": [0.6, 0.1, 0.1, 0.05, 0.075, 0.075] } },
        "city": { "strategy": "city", "options": { "country": "{{country}}" } },
        "postcode": { "strategy": "postcode", "options": { "country": "{{country}}" } },
        "latitude": { "strategy": "float", "options": { "min": -90, "max": 90, "precision": 6 } },
        "longitude": { "strategy": "float", "options": { "min": -180, "max": 180, "precision": 6 } },
        "created_at": { "strategy": "timestamp", "options": { "mode": "past", "start": "2020-01-01", "end": "2025-12-31" } },
        "status": { "strategy": "enum", "options": { "values": ["active", "suspended", "closed"], "weights": [0.85, 0.1, 0.05] } }
      }
    },
    "accounts": {
      "columns": {
        "account_id": { "strategy": "uuid" },
        "customer_id": { "strategy": "foreign_key", "options": { "table": "customers", "column": "customer_id" } },
        "account_type": { "strategy": "enum", "options": { "values": ["checking", "savings", "credit"], "weights": [0.7, 0.2, 0.1] } },
        "balance": { "strategy": "money", "options": { "min": 0, "max": 50000, "distribution": "log-normal" } },
        "opened_at": { "strategy": "timestamp", "options": { "mode": "past", "start": "2020-01-01", "end": "2025-12-31" } },
        "closed_at": { "strategy": "null", "options": { "null_probability": 0.9 } }
      },
      "lifecycle": {
        "status": "active",
        "transitions": [
          { "from": "active", "to": "closed", "condition": "closed_at IS NOT NULL" }
        ],
        "rules": [
          { "if": "closed_at IS NOT NULL", "then": "balance = 0" }
        ]
      }
    },
    "merchants": {
      "columns": {
        "merchant_id": { "strategy": "uuid" },
        "name": { "strategy": "company_name" },
        "category": { "strategy": "enum", "options": { "values": ["retail", "restaurant", "travel", "entertainment", "healthcare", "other"], "weights": [0.3, 0.2, 0.15, 0.15, 0.1, 0.1] } },
        "country": { "strategy": "enum", "options": { "values": ["US", "GB", "CA", "AU", "DE", "FR"], "weights": [0.6, 0.1, 0.1, 0.05, 0.075, 0.075] } },
        "city": { "strategy": "city", "options": { "country": "{{country}}" } },
        "latitude": { "strategy": "float", "options": { "min": -90, "max": 90, "precision": 6 } },
        "longitude": { "strategy": "float", "options": { "min": -180, "max": 180, "precision": 6 } }
      }
    },
    "transactions": {
      "columns": {
        "transaction_id": { "strategy": "uuid" },
        "account_id": { "strategy": "foreign_key", "options": { "table": "accounts", "column": "account_id" } },
        "merchant_id": { "strategy": "foreign_key", "options": { "table": "merchants", "column": "merchant_id", "null_probability": 0.2 } },
        "amount": { "strategy": "money", "options": { "min": 1, "max": 10000, "distribution": "log-normal" } },
        "transaction_type": { "strategy": "enum", "options": { "values": ["purchase", "withdrawal", "deposit", "transfer"], "weights": [0.6, 0.2, 0.1, 0.1] } },
        "timestamp": { "strategy": "timestamp", "options": { "mode": "past", "start": "2020-01-01", "end": "2025-12-31" } },
        "is_fraud": { "strategy": "enum", "options": { "values": [true, false], "weights": [0.02, 0.98] } },
        "location_ip_country": { "strategy": "enum", "options": { "values": ["US", "GB", "CA", "AU", "DE", "FR", "other"], "weights": [0.5, 0.1, 0.1, 0.05, 0.1, 0.05, 0.1] } }
      },
      "temporal": [
        { "field": "timestamp", "after": "accounts.opened_at", "using": "account_id" }
      ],
      "lifecycle": {
        "rules": [
          { "if": "transaction_type = 'transfer' AND amount > 10000", "then": "is_fraud = true" }
        ]
      }
    },
    "fraud_alerts": {
      "columns": {
        "alert_id": { "strategy": "uuid" },
        "transaction_id": { "strategy": "foreign_key", "options": { "table": "transactions", "column": "transaction_id" } },
        "alert_time": { "strategy": "timestamp", "options": { "mode": "past", "start": "2020-01-01", "end": "2025-12-31" } },
        "severity": { "strategy": "enum", "options": { "values": ["low", "medium", "high"], "weights": [0.5, 0.3, 0.2] } },
        "status": { "strategy": "enum", "options": { "values": ["open", "investigating", "resolved", "false_positive"], "weights": [0.2, 0.3, 0.3, 0.2] } }
      },
      "temporal": [
        { "field": "alert_time", "after": "transactions.timestamp", "using": "transaction_id" }
      ]
    }
  },
  "relationships": [
    { "from": "accounts", "to": "customers", "via": "customer_id" },
    { "from": "transactions", "to": "accounts", "via": "account_id" },
    { "from": "transactions", "to": "merchants", "via": "merchant_id", "nullable": true },
    { "from": "fraud_alerts", "to": "transactions", "via": "transaction_id" }
  ]
}