{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Exported from RealityDB Studio",
  "tables": {
    "customers": {
      "match": "customers",
      "columns": {
        "customer_id": {
          "strategy": "uuid"
        },
        "full_name": {
          "strategy": "full_name"
        },
        "email": {
          "strategy": "email"
        },
        "phone": {
          "strategy": "phone"
        },
        "country": {
          "strategy": "enum",
          "options": {
            "values": [
              "US",
              "GB",
              "CA",
              "AU",
              "DE",
              "FR"
            ],
            "weights": [
              0.6,
              0.1,
              0.1,
              0.05,
              0.075,
              0.075
            ]
          }
        },
        "city": {
          "strategy": "text"
        },
        "postcode": {
          "strategy": "text"
        },
        "latitude": {
          "strategy": "float",
          "options": {
            "min": -90,
            "max": 90
          }
        },
        "longitude": {
          "strategy": "float",
          "options": {
            "min": -180,
            "max": 180
          }
        },
        "created_at": {
          "strategy": "timestamp"
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "active",
              "suspended",
              "closed"
            ],
            "weights": [
              0.85,
              0.1,
              0.05
            ]
          }
        }
      }
    },
    "accounts": {
      "match": "accounts",
      "columns": {
        "account_id": {
          "strategy": "uuid"
        },
        "customer_id": {
          "strategy": "text"
        },
        "account_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "checking",
              "savings",
              "credit"
            ],
            "weights": [
              0.7,
              0.2,
              0.1
            ]
          }
        },
        "balance": {
          "strategy": "text"
        },
        "opened_at": {
          "strategy": "timestamp"
        },
        "closed_at": {
          "strategy": "text"
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "merchants": {
      "match": "merchants",
      "columns": {
        "merchant_id": {
          "strategy": "uuid"
        },
        "name": {
          "strategy": "company_name"
        },
        "category": {
          "strategy": "enum",
          "options": {
            "values": [
              "retail",
              "restaurant",
              "travel",
              "entertainment",
              "healthcare",
              "other"
            ],
            "weights": [
              0.3,
              0.2,
              0.15,
              0.15,
              0.1,
              0.1
            ]
          }
        },
        "country": {
          "strategy": "enum",
          "options": {
            "values": [
              "US",
              "GB",
              "CA",
              "AU",
              "DE",
              "FR"
            ],
            "weights": [
              0.6,
              0.1,
              0.1,
              0.05,
              0.075,
              0.075
            ]
          }
        },
        "city": {
          "strategy": "text"
        },
        "latitude": {
          "strategy": "float",
          "options": {
            "min": -90,
            "max": 90
          }
        },
        "longitude": {
          "strategy": "float",
          "options": {
            "min": -180,
            "max": 180
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "transactions": {
      "match": "transactions",
      "columns": {
        "transaction_id": {
          "strategy": "uuid"
        },
        "account_id": {
          "strategy": "text"
        },
        "merchant_id": {
          "strategy": "text"
        },
        "amount": {
          "strategy": "text"
        },
        "transaction_type": {
          "strategy": "enum",
          "options": {
            "values": [
              "purchase",
              "withdrawal",
              "deposit",
              "transfer"
            ],
            "weights": [
              0.6,
              0.2,
              0.1,
              0.1
            ]
          }
        },
        "timestamp": {
          "strategy": "timestamp"
        },
        "is_fraud": {
          "strategy": "enum",
          "options": {
            "values": [
              true,
              false
            ],
            "weights": [
              0.02,
              0.98
            ]
          }
        },
        "location_ip_country": {
          "strategy": "enum",
          "options": {
            "values": [
              "US",
              "GB",
              "CA",
              "AU",
              "DE",
              "FR",
              "other"
            ],
            "weights": [
              0.5,
              0.1,
              0.1,
              0.05,
              0.1,
              0.05,
              0.1
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    },
    "fraud_alerts": {
      "match": "fraud_alerts",
      "columns": {
        "alert_id": {
          "strategy": "uuid"
        },
        "transaction_id": {
          "strategy": "text"
        },
        "alert_time": {
          "strategy": "timestamp"
        },
        "severity": {
          "strategy": "enum",
          "options": {
            "values": [
              "low",
              "medium",
              "high"
            ],
            "weights": [
              0.5,
              0.3,
              0.2
            ]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": [
              "open",
              "investigating",
              "resolved",
              "false_positive"
            ],
            "weights": [
              0.2,
              0.3,
              0.3,
              0.2
            ]
          }
        },
        "created_at": {
          "strategy": "timestamp"
        }
      }
    }
  },
  "simulation": {
    "seed": 123,
    "timelineDays": 180,
    "growthCurve": "s-curve",
    "anomalyRate": 0.08
  },
  "generationConfig": {
    "database": {
      "client": "postgres"
    },
    "seed": {
      "defaultRecords": 1000,
      "randomSeed": 123
    }
  }
}