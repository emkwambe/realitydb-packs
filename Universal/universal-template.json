{
  "name": "Universal Starter",
  "version": "1.0.0",
  "description": "6 cross-industry tables that exist in every application — users, audit logs, API requests, errors, addresses, transactions. Zero configuration needed.",
  "domain": "universal",
  "tables": {
    "users": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "email": {
          "type": "varchar",
          "strategy": "template",
          "options": {
            "template": "user_{{rowIndex}}@example.dev"
          }
        },
        "full_name": {
          "type": "varchar",
          "strategy": "full_name"
        },
        "role": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "admin",
              "customer",
              "employee",
              "manager",
              "support",
              "developer"
            ]
          }
        },
        "created_at": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 3
          }
        },
        "last_active_at": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 1
          }
        },
        "is_active": {
          "type": "boolean",
          "strategy": "boolean",
          "options": {
            "trueWeight": 0.85
          }
        }
      }
    },
    "addresses": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "user_id": {
          "type": "uuid",
          "foreignKey": {
            "table": "users",
            "column": "id"
          }
        },
        "street": {
          "type": "varchar",
          "strategy": "template",
          "options": {
            "template": "{{number}} Synthetic Ave Unit {{rowIndex}}"
          }
        },
        "city": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "New York",
              "Los Angeles",
              "Chicago",
              "Houston",
              "Phoenix",
              "London",
              "Manchester",
              "Berlin",
              "Munich",
              "Toronto",
              "Vancouver",
              "Montreal"
            ]
          }
        },
        "state": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "NY",
              "CA",
              "IL",
              "TX",
              "AZ",
              "ENG",
              "ENG",
              "BE",
              "BY",
              "ON",
              "BC",
              "QC"
            ]
          }
        },
        "postal_code": {
          "type": "varchar",
          "strategy": "zip_code"
        },
        "country": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "US",
              "GB",
              "DE",
              "CA"
            ]
          }
        },
        "address_type": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "home",
              "work",
              "shipping",
              "billing"
            ]
          }
        },
        "created_at": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 2
          }
        }
      }
    },
    "transactions": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "user_id": {
          "type": "uuid",
          "foreignKey": {
            "table": "users",
            "column": "id"
          }
        },
        "amount": {
          "type": "decimal",
          "strategy": "number",
          "options": {
            "min": 1,
            "max": 9999.99,
            "precision": 2
          }
        },
        "currency": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "USD",
              "EUR",
              "GBP",
              "CAD",
              "AUD",
              "JPY"
            ]
          }
        },
        "status": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "pending",
              "completed",
              "failed",
              "refunded",
              "cancelled"
            ]
          }
        },
        "payment_method": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "credit_card",
              "debit_card",
              "bank_transfer",
              "paypal",
              "stripe",
              "crypto",
              "apple_pay"
            ]
          }
        },
        "transaction_type": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "purchase",
              "refund",
              "transfer",
              "subscription",
              "donation",
              "payout"
            ]
          }
        },
        "description": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "Monthly subscription",
              "One-time purchase",
              "Service payment",
              "Product order",
              "Membership renewal",
              "Upgrade fee",
              "Setup charge",
              "Consulting fee",
              "License renewal",
              "Support plan"
            ]
          }
        },
        "created_at": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 2
          }
        }
      }
    },
    "audit_logs": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "user_id": {
          "type": "uuid",
          "foreignKey": {
            "table": "users",
            "column": "id"
          }
        },
        "action": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "CREATE",
              "READ",
              "UPDATE",
              "DELETE",
              "LOGIN",
              "LOGOUT",
              "EXPORT",
              "IMPORT",
              "APPROVE",
              "REJECT"
            ]
          }
        },
        "resource_type": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "user",
              "order",
              "invoice",
              "report",
              "setting",
              "document",
              "project",
              "ticket",
              "payment",
              "subscription"
            ]
          }
        },
        "resource_id": {
          "type": "varchar",
          "strategy": "uuid"
        },
        "ip_address": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "10.0.1.1",
              "10.0.1.2",
              "10.0.1.3",
              "10.0.2.1",
              "10.0.2.2",
              "192.168.1.100",
              "192.168.1.101",
              "192.168.1.102",
              "192.168.2.50",
              "172.16.0.10",
              "172.16.0.11",
              "172.16.0.12",
              "172.16.1.1"
            ]
          }
        },
        "user_agent": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/124.0",
              "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) Safari/605.1",
              "Mozilla/5.0 (X11; Linux x86_64) Firefox/125.0",
              "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4) Mobile/15E148",
              "PostmanRuntime/7.37.0",
              "axios/1.6.8",
              "python-requests/2.31.0",
              "curl/8.6.0"
            ]
          }
        },
        "timestamp": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 1
          }
        }
      }
    },
    "api_requests": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "user_id": {
          "type": "uuid",
          "foreignKey": {
            "table": "users",
            "column": "id"
          }
        },
        "endpoint": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "/api/v1/users",
              "/api/v1/users/:id",
              "/api/v1/orders",
              "/api/v1/orders/:id",
              "/api/v1/products",
              "/api/v1/auth/login",
              "/api/v1/auth/refresh",
              "/api/v1/payments",
              "/api/v1/reports",
              "/api/v1/webhooks",
              "/api/v1/search",
              "/api/v1/settings",
              "/api/v2/analytics",
              "/api/v2/exports",
              "/health",
              "/graphql"
            ]
          }
        },
        "method": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          }
        },
        "status_code": {
          "type": "integer",
          "strategy": "enum",
          "options": {
            "values": [
              "200",
              "201",
              "204",
              "301",
              "400",
              "401",
              "403",
              "404",
              "422",
              "429",
              "500",
              "502",
              "503"
            ]
          }
        },
        "duration_ms": {
          "type": "integer",
          "strategy": "number",
          "options": {
            "min": 5,
            "max": 3000
          }
        },
        "ip_address": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "10.0.1.1",
              "10.0.1.2",
              "10.0.1.3",
              "10.0.2.1",
              "10.0.2.2",
              "192.168.1.100",
              "192.168.1.101",
              "192.168.1.102",
              "192.168.2.50",
              "172.16.0.10",
              "172.16.0.11",
              "172.16.0.12",
              "172.16.1.1"
            ]
          }
        },
        "timestamp": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 1
          }
        }
      }
    },
    "errors": {
      "columns": {
        "id": {
          "type": "uuid",
          "primary": true,
          "strategy": "uuid"
        },
        "error_type": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "NullPointerException",
              "TimeoutError",
              "ValidationError",
              "AuthenticationError",
              "PermissionDenied",
              "RateLimitExceeded",
              "DatabaseConnectionError",
              "SerializationError",
              "FileNotFoundError",
              "OutOfMemoryError",
              "NetworkError",
              "ConcurrencyConflict",
              "InvalidStateTransition",
              "PaymentDeclined",
              "ExternalServiceUnavailable"
            ]
          }
        },
        "message": {
          "type": "text",
          "strategy": "enum",
          "options": {
            "values": [
              "Connection timed out after 30000ms",
              "Required field 'email' is missing",
              "Invalid token: expired at 2026-01-15T00:00:00Z",
              "User does not have permission to access resource",
              "Rate limit exceeded: 100 requests per minute",
              "Failed to connect to database: connection refused",
              "Cannot serialize object of type 'Buffer'",
              "File '/uploads/report.pdf' not found",
              "Heap space exceeded: allocated 512MB",
              "DNS resolution failed for api.external-service.com",
              "Optimistic lock conflict on record #4821",
              "Cannot transition order from 'shipped' to 'pending'",
              "Payment declined: insufficient funds",
              "External service returned HTTP 503"
            ]
          }
        },
        "severity": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "warning",
              "error",
              "critical",
              "fatal"
            ]
          }
        },
        "source_service": {
          "type": "varchar",
          "strategy": "enum",
          "options": {
            "values": [
              "api-gateway",
              "auth-service",
              "payment-service",
              "notification-service",
              "worker-queue",
              "search-indexer",
              "file-processor",
              "analytics-pipeline"
            ]
          }
        },
        "occurrence_count": {
          "type": "integer",
          "strategy": "number",
          "options": {
            "min": 1,
            "max": 500
          }
        },
        "first_seen": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 1
          }
        },
        "last_seen": {
          "type": "timestamp",
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 0
          }
        },
        "resolved": {
          "type": "boolean",
          "strategy": "boolean",
          "options": {
            "trueWeight": 0.6
          }
        }
      }
    }
  }
}