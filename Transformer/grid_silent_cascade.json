{
  "name": "grid_silent_cascade",
  "version": "3.0",
  "description": "Power grid ferroresonance dataset (structural skeleton). v3.0: migrated to RealityDB pack spec — count_factor declarations removed, relationships block uses spec format with cardinality declarations driving variable distribution, ferroresonance_events FK ordering fixed so switching_events is the primary parent (correct 2-4% rare-event ratio). Float distributions (Weibull, Normal) are honored by engine v2.39+. NOT a full SDE-driven research dataset — see _meta.scope_disclosure.",

  "_meta": {
    "research_score": "9.5/10 (intent); 6/10 (engine fidelity)",
    "scope_disclosure": "This pack provides a STRUCTURAL skeleton for ferroresonance research with realistic enum distributions and rare-event cardinality (2-4% ferroresonance per switching event). It does NOT generate the SDE-driven time-series at 10kHz, persistent homology features, or multivariate correlations described in the original research design. Float columns declare Weibull/Normal distributions which the engine honors via Box-Muller and inverse-CDF sampling but with independent draws (no temporal correlation). For full research fidelity (SDE simulation, TDA computation, GNN training data) a separate generator pipeline is required.",
    "post_generation_validation": [
      {
        "rule": "temporal_ordering_switching_to_ferro",
        "sql": "SELECT f.id FROM ferroresonance_events f JOIN switching_events s ON f.switching_event_id = s.id WHERE s.event_time >= f.detected_at;"
      },
      {
        "rule": "temporal_ordering_ferro_to_cascade",
        "sql": "SELECT c.id FROM cascade_gradients c JOIN ferroresonance_events f ON c.ferroresonance_event_id = f.id WHERE c.timestamp < f.detected_at;"
      },
      {
        "rule": "conditional_nulls_non_ferro_rows",
        "sql": "UPDATE ferroresonance_events SET peak_overvoltage_pu = NULL, duration_ms = NULL WHERE is_label_positive = 'false';"
      },
      {
        "rule": "reactance_length_consistency",
        "sql": "SELECT id, length_km, x_ohm, round(length_km * 0.35, 3) AS expected_x FROM lines WHERE abs(x_ohm - length_km * 0.35) / (length_km * 0.35) > 0.40;"
      },
      {
        "rule": "cascade_orphan_check",
        "sql": "SELECT c.id FROM cascade_gradients c LEFT JOIN ferroresonance_events f ON c.ferroresonance_event_id = f.id WHERE f.id IS NULL;"
      }
    ]
  },

  "tables": {
    "buses": {
      "match": "buses",
      "columns": {
        "id": { "strategy": "uuid" },
        "bus_type": {
          "strategy": "enum",
          "options": { "values": ["substation","pv_farm","ev_charger","load"], "weights": [5,15,10,70] }
        },
        "nominal_voltage_kv": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 20, "stddev": 2, "min": 10, "max": 35 }
        },
        "latitude": {
          "strategy": "float",
          "options": { "distribution": "uniform", "min": 35, "max": 48 }
        },
        "longitude": {
          "strategy": "float",
          "options": { "distribution": "uniform", "min": -125, "max": -65 }
        }
      }
    },

    "lines": {
      "match": "lines",
      "columns": {
        "id": { "strategy": "uuid" },
        "from_bus_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "buses", "column": "id" }
        },
        "to_bus_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "buses", "column": "id" }
        },
        "length_km": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 1.5, "lambda": 8, "min": 1, "max": 30 }
        },
        "r_ohm": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 1.2, "stddev": 0.4, "min": 0.12, "max": 3.6 }
        },
        "x_ohm": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 2.8, "stddev": 0.9, "min": 0.35, "max": 10.5 }
        },
        "c0_nf_per_km": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 0.008, "stddev": 0.001, "min": 0.004, "max": 0.014 }
        },
        "c1_nf_per_km": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 0.012, "stddev": 0.002, "min": 0.006, "max": 0.020 }
        }
      }
    },

    "transformers": {
      "match": "transformers",
      "columns": {
        "id": { "strategy": "uuid" },
        "bus_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "buses", "column": "id" }
        },
        "core_type": {
          "strategy": "enum",
          "options": { "values": ["standard","low_loss"], "weights": [80,20] }
        },
        "remanent_flux_pu": {
          "strategy": "float",
          "options": { "distribution": "uniform", "min": 0.0, "max": 0.8 }
        },
        "core_loss_resistance_pu": {
          "strategy": "float",
          "options": { "distribution": "uniform", "min": 0.5, "max": 4.0 }
        },
        "rating_kva": {
          "strategy": "enum",
          "options": { "values": ["25","50","100","167","250","500","1000"], "weights": [10,20,30,15,12,10,3] }
        }
      }
    },

    "pv_systems": {
      "match": "pv_systems",
      "columns": {
        "id": { "strategy": "uuid" },
        "bus_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "buses", "column": "id" }
        },
        "irradiance_profile": {
          "strategy": "enum",
          "options": { "values": ["clear","partial_cloud","overcast"], "weights": [50,30,20] }
        },
        "capacity_kw": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 1.8, "lambda": 500, "min": 10, "max": 5000 }
        },
        "inverter_type": {
          "strategy": "enum",
          "options": { "values": ["string","central","microinverter"], "weights": [40,45,15] }
        },
        "grid_forming": {
          "strategy": "enum",
          "options": { "values": ["true","false"], "weights": [12,88] }
        }
      }
    },

    "switching_events": {
      "match": "switching_events",
      "columns": {
        "id": { "strategy": "uuid" },
        "line_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "lines", "column": "id" },
          "nullable": true,
          "null_probability": 0.1
        },
        "transformer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "transformers", "column": "id" },
          "nullable": true,
          "null_probability": 0.2
        },
        "event_type": {
          "strategy": "enum",
          "options": { "values": ["line_closing","capacitor_switching","load_tap_change","fault_clearing"], "weights": [40,30,20,10] }
        },
        "switching_angle_deg": {
          "strategy": "float",
          "options": { "distribution": "uniform", "min": 0.0, "max": 360.0 }
        },
        "event_time": {
          "strategy": "timestamp",
          "options": { "start": "2020-01-01", "end": "2025-12-31", "distribution": "uniform" }
        },
        "operator_initiated": {
          "strategy": "enum",
          "options": { "values": ["true","false"], "weights": [35,65] }
        },
        "protection_zone": {
          "strategy": "enum",
          "options": { "values": ["zone_1","zone_2","zone_3","unzoned"], "weights": [25,35,30,10] }
        }
      }
    },

    "ferroresonance_events": {
      "match": "ferroresonance_events",
      "columns": {
        "id": { "strategy": "uuid" },
        "switching_event_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "switching_events", "column": "id" },
          "nullable": true,
          "null_probability": 0.05
        },
        "line_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "lines", "column": "id" }
        },
        "ferro_mode": {
          "strategy": "enum",
          "options": { "values": ["fundamental","sub_harmonic","chaotic"], "weights": [40,35,25] }
        },
        "is_label_positive": {
          "strategy": "enum",
          "options": { "values": ["true","false"], "weights": [2,98] }
        },
        "peak_overvoltage_pu": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 2.5, "lambda": 1.8, "min": 1.1, "max": 4.5 }
        },
        "duration_ms": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 1.2, "lambda": 150, "min": 20, "max": 5000 }
        },
        "detected_at": {
          "strategy": "timestamp",
          "options": { "start": "2020-01-02", "end": "2026-12-31", "distribution": "uniform" }
        },
        "suppressed_by_relay": {
          "strategy": "enum",
          "options": { "values": ["true","false"], "weights": [60,40] }
        }
      }
    },

    "cascade_gradients": {
      "match": "cascade_gradients",
      "columns": {
        "id": { "strategy": "uuid" },
        "ferroresonance_event_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "ferroresonance_events", "column": "id" }
        },
        "line_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "lines", "column": "id" }
        },
        "timestamp": {
          "strategy": "timestamp",
          "options": { "start": "2020-01-02", "end": "2026-12-31", "distribution": "uniform" }
        },
        "stress_value": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 2.0, "lambda": 100, "min": 0.1, "max": 500 }
        },
        "propagation_depth": {
          "strategy": "integer",
          "options": { "min": 1, "max": 8 }
        },
        "affected_bus_count": {
          "strategy": "integer",
          "options": { "min": 1, "max": 25 }
        },
        "gradient_direction": {
          "strategy": "enum",
          "options": { "values": ["upstream","downstream","lateral"], "weights": [30,55,15] }
        }
      }
    },

    "tda_features": {
      "match": "tda_features",
      "columns": {
        "id": { "strategy": "uuid" },
        "switching_event_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "switching_events", "column": "id" }
        },
        "line_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "lines", "column": "id" }
        },
        "beta0": {
          "strategy": "integer",
          "options": { "min": 1, "max": 15 }
        },
        "beta1": {
          "strategy": "integer",
          "options": { "min": 0, "max": 8 }
        },
        "d_beta0_dt": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 0.0, "stddev": 25.0, "min": -200, "max": 200 }
        },
        "persistence_entropy": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 2.1, "stddev": 0.6, "min": 0.0, "max": 5.0 }
        },
        "betti_ratio": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 1.4, "stddev": 0.8, "min": 0.0, "max": 10.0 }
        },
        "wasserstein_distance": {
          "strategy": "float",
          "options": { "distribution": "weibull", "k": 1.3, "lambda": 0.5, "min": 0.0, "max": 5.0 }
        }
      }
    }
  },

  "relationships": [
    {
      "targetTable": "lines",
      "cardinality": { "strategy": "poisson", "mean": 2.0, "min": 1, "max": 5 }
    },
    {
      "targetTable": "transformers",
      "cardinality": { "strategy": "poisson", "mean": 1.0, "min": 1, "max": 3 }
    },
    {
      "targetTable": "pv_systems",
      "cardinality": { "strategy": "poisson", "mean": 0.2, "min": 0, "max": 2 }
    },
    {
      "targetTable": "switching_events",
      "cardinality": { "strategy": "poisson", "mean": 5.0, "min": 1, "max": 20 }
    },
    {
      "targetTable": "ferroresonance_events",
      "cardinality": { "strategy": "fixed", "mean": 0.04, "min": 0, "max": 1 }
    },
    {
      "targetTable": "tda_features",
      "cardinality": { "strategy": "poisson", "mean": 3.0, "min": 1, "max": 8 }
    },
    {
      "targetTable": "cascade_gradients",
      "cardinality": { "strategy": "poisson", "mean": 0.5, "min": 0, "max": 3 }
    }
  ]
}
