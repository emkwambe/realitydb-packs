{
  "tables": [
    {
      "id": "tbl-001",
      "name": "patients",
      "columns": [
        { "id": "tbl-001-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-001-c2", "name": "mrn", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "template", "options": { "template": "IO-{{rowIndex}}" } },
        { "id": "tbl-001-c3", "name": "full_name", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "full_name", "options": {} },
        { "id": "tbl-001-c4", "name": "date_of_birth", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 30, "maxYearsAgo": 85 } },
        { "id": "tbl-001-c5", "name": "sex", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["male", "female"], "weights": [55, 45], "_citation": "IO trials: Slightly more males due to NSCLC/melanoma predominance. Male ~55%, Female ~45%." } },
        { "id": "tbl-001-c6", "name": "primary_tumor", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["NSCLC", "melanoma", "renal_cell", "urothelial", "head_neck", "colorectal_MSI_H", "gastric", "hepatocellular", "TNBC", "hodgkin_lymphoma", "merkel_cell", "other"], "weights": [25, 15, 10, 8, 7, 6, 5, 5, 5, 4, 2, 8], "_citation": "FDA approved IO indications: NSCLC largest (~25%). Melanoma pioneered IO (~15%). RCC ~10%. Pan-tumor MSI-H/TMB-H approvals." } },
        { "id": "tbl-001-c7", "name": "stage", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["IIIA", "IIIB", "IIIC", "IVA", "IVB"], "weights": [10, 10, 5, 45, 30], "_citation": "IO primarily used in advanced/metastatic disease. Stage IV ~75% of IO-treated patients. Stage III in consolidation (durvalumab PACIFIC)." } },
        { "id": "tbl-001-c8", "name": "ecog_baseline", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["0", "1", "2"], "weights": [30, 50, 20], "_citation": "IO trial enrollment: ECOG 0-1 required for most trials. ECOG 2 in select real-world patients. CheckMate 171 included ECOG 2." } },
        { "id": "tbl-001-c9", "name": "prior_lines", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["0_treatment_naive", "1_prior", "2_prior", "3_plus_prior"], "weights": [40, 30, 18, 12], "_citation": "IO increasingly first-line (~40%). KEYNOTE-024/189, CheckMate 227 established 1L IO. Still used in 2L+ (~30%)." } },
        { "id": "tbl-001-c10", "name": "autoimmune_history", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["none", "thyroid_disease", "rheumatoid_arthritis", "psoriasis", "IBD", "type1_diabetes", "other"], "weights": [75, 8, 4, 3, 3, 2, 5], "_citation": "IO trials historically excluded autoimmune disease. RWD shows ~25% have pre-existing autoimmune conditions. Thyroid most common." } },
        { "id": "tbl-001-c11", "name": "created_at", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "tbl-002",
      "name": "biomarker_panel",
      "columns": [
        { "id": "tbl-002-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-002-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-002-c3", "name": "pd_l1_tps", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["negative_0", "low_1_49", "high_50_plus"], "weights": [45, 30, 25], "_citation": "KEYNOTE trials: PD-L1 TPS <1% ~45%, 1-49% ~30%, >=50% ~25%. Blueprint comparability study." } },
        { "id": "tbl-002-c4", "name": "pd_l1_antibody", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["22C3_Dako", "28-8_Dako", "SP263_Ventana", "SP142_Ventana", "73-10_Dako"], "weights": [35, 25, 20, 15, 5], "_citation": "PD-L1 IHC Blueprint: 22C3 (pembrolizumab companion Dx) most common. 28-8 (nivolumab). SP263 (durvalumab). SP142 (atezolizumab)." } },
        { "id": "tbl-002-c5", "name": "tmb_mut_per_mb", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 0.5, "max": 60, "precision": 1 } },
        { "id": "tbl-002-c6", "name": "tmb_category", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["low", "intermediate", "high"], "weights": [50, 30, 20], "_citation": "FDA: TMB-H defined >=10 mut/Mb (FoundationOne CDx). ~20% of solid tumors TMB-H. KEYNOTE-158 pan-tumor approval." } },
        { "id": "tbl-002-c7", "name": "msi_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["MSS", "MSI_low", "MSI_high"], "weights": [82, 5, 13], "_citation": "KEYNOTE-177: MSI-H in ~15% of CRC, ~3-4% of all solid tumors. MSS majority. MSI-H predicts IO response." } },
        { "id": "tbl-002-c8", "name": "mmr_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["proficient", "deficient"], "weights": [85, 15], "_citation": "dMMR correlates with MSI-H. ~15% deficient. IHC for MLH1/MSH2/MSH6/PMS2." } },
        { "id": "tbl-002-c9", "name": "testing_platform", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["FoundationOne_CDx", "Tempus_xT", "Guardant360", "MSK_IMPACT", "Caris_MI_Profile", "local_NGS", "IHC_only"], "weights": [25, 15, 12, 10, 8, 15, 15], "_citation": "FDA-approved CDx: F1CDx for TMB/MSI. Tempus/Guardant commercial labs. MSK-IMPACT academic. ~15% IHC only (PD-L1 without NGS)." } },
        { "id": "tbl-002-c10", "name": "report_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 420, "y": 100 }
    },
    {
      "id": "tbl-003",
      "name": "tissue_biopsy",
      "columns": [
        { "id": "tbl-003-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-003-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-003-c3", "name": "biopsy_site", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["primary_tumor", "lymph_node", "liver_met", "lung_met", "bone_met", "brain_met", "skin_met", "soft_tissue"], "weights": [35, 15, 12, 12, 8, 5, 8, 5], "_citation": "Clinical practice: Primary tumor biopsy most common (~35%). Metastatic sites for rebiopsy. Liver/lung most accessible mets." } },
        { "id": "tbl-003-c4", "name": "cd8_til_density", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["absent", "low", "moderate", "high", "brisk"], "weights": [10, 25, 30, 25, 10], "_citation": "Galon Immunoscore: CD8+ TIL density correlates with IO response. Brisk infiltrate (~10%) best prognosis. Absent (~10%) poor IO response." } },
        { "id": "tbl-003-c5", "name": "cd4_helper_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 1, "max": 45, "precision": 1 } },
        { "id": "tbl-003-c6", "name": "treg_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 0.5, "max": 25, "precision": 1 } },
        { "id": "tbl-003-c7", "name": "mdsc_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 0.1, "max": 20, "precision": 1 } },
        { "id": "tbl-003-c8", "name": "m1_macrophage_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 1, "max": 30, "precision": 1 } },
        { "id": "tbl-003-c9", "name": "m2_macrophage_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 1, "max": 35, "precision": 1 } },
        { "id": "tbl-003-c10", "name": "immune_phenotype", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["inflamed_hot", "immune_excluded", "immune_desert"], "weights": [30, 40, 30], "_citation": "Chen-Mellman 2017 Nature: Inflamed (~30%) respond best to IO. Immune-excluded (~40%) partial response. Desert (~30%) IO-resistant." } },
        { "id": "tbl-003-c11", "name": "biopsy_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 740, "y": 100 }
    },
    {
      "id": "tbl-004",
      "name": "immunotherapy_cycles",
      "columns": [
        { "id": "tbl-004-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-004-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-004-c3", "name": "regimen", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["pembrolizumab_mono", "nivolumab_mono", "atezolizumab_mono", "durvalumab_mono", "ipilimumab_nivolumab", "pembrolizumab_chemo", "nivolumab_chemo", "atezolizumab_chemo", "tremelimumab_durvalumab", "cemiplimab"], "weights": [18, 12, 8, 8, 12, 15, 5, 8, 5, 4], "_citation": "NCCN: Pembro most prescribed IO globally. Ipi+nivo for melanoma/RCC/NSCLC. Pembro+chemo KEYNOTE-189. Atezo+chemo IMpower150." } },
        { "id": "tbl-004-c4", "name": "cycle_number", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 35 } },
        { "id": "tbl-004-c5", "name": "dose_mg", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 1, "max": 500, "precision": 0 } },
        { "id": "tbl-004-c6", "name": "schedule", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["Q2W", "Q3W", "Q4W", "Q6W"], "weights": [30, 35, 25, 10], "_citation": "FDA labels: Pembro Q3W or Q6W. Nivo Q2W or Q4W. Atezo Q2W or Q3W or Q4W. Trend toward Q6W extended dosing." } },
        { "id": "tbl-004-c7", "name": "cycle_outcome", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["completed", "delayed", "held_irae", "dose_omitted", "discontinued"], "weights": [55, 15, 12, 8, 10], "_citation": "IO trials: ~55% cycles on schedule. ~15% delayed. ~12% held for irAE. ~10% discontinued." } },
        { "id": "tbl-004-c8", "name": "infusion_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 1060, "y": 100 }
    },
    {
      "id": "tbl-005",
      "name": "immune_related_aes",
      "columns": [
        { "id": "tbl-005-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-005-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-005-c3", "name": "cycle_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-005-c4", "name": "irae_type", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["dermatitis", "colitis", "hepatitis", "pneumonitis", "thyroiditis", "hypophysitis", "adrenal_insufficiency", "type1_diabetes", "myocarditis", "nephritis", "neurotoxicity", "myositis", "uveitis"], "weights": [18, 12, 10, 10, 12, 5, 4, 2, 2, 4, 3, 3, 3], "_citation": "PMC8144509: Skin irAEs most common (~18%). Thyroid ~12%. Colitis ~12% (higher with CTLA-4). Pneumonitis ~10% (higher with PD-1). Myocarditis rare (~2%) but fatal." } },
        { "id": "tbl-005-c5", "name": "ctcae_grade", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["1", "2", "3", "4", "5"], "weights": [30, 30, 25, 10, 2], "_citation": "PMC8144509: Grade 3+ irAEs ~17.7% mono, ~54.3% combo. Grade 5 ~1-2%. irAEs tend to be higher grade than general AEs." } },
        { "id": "tbl-005-c6", "name": "time_to_onset_weeks", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 52 } },
        { "id": "tbl-005-c7", "name": "management", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["observation", "topical_steroids", "oral_prednisone", "iv_methylprednisolone", "infliximab", "mycophenolate", "io_held", "io_discontinued", "hospitalized"], "weights": [15, 10, 20, 10, 5, 3, 12, 12, 8], "_citation": "ASCO/NCCN irAE guidelines: Grade 1=observe. Grade 2=oral steroids. Grade 3=IV steroids+hold IO. Grade 4=discontinue+immunosuppression. Infliximab for refractory colitis." } },
        { "id": "tbl-005-c8", "name": "resolution_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["resolved", "resolved_with_sequelae", "not_resolved", "fatal"], "weights": [50, 20, 25, 5], "_citation": "IO irAE data: ~50% resolve completely. ~20% resolve with chronic sequelae (endocrine replacement). ~25% ongoing. ~5% fatal (myocarditis, pneumonitis)." } },
        { "id": "tbl-005-c9", "name": "io_rechallenge", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["yes_same_agent", "yes_different_agent", "no_permanent_discontinuation", "not_applicable"], "weights": [15, 8, 35, 42], "_citation": "IO rechallenge: ~15-25% rechallenged after irAE resolution. ~50-60% recurrence of same or new irAE. Most Grade 3+ permanently discontinued." } },
        { "id": "tbl-005-c10", "name": "onset_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 3 } }
      ],
      "position": { "x": 100, "y": 400 }
    },
    {
      "id": "tbl-006",
      "name": "response_assessments",
      "columns": [
        { "id": "tbl-006-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-006-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-006-c3", "name": "assessment_criteria", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["RECIST_1.1", "iRECIST", "irRECIST", "mRECIST"], "weights": [40, 35, 15, 10], "_citation": "iRECIST 2017: Designed for IO response evaluation. Accounts for pseudo-progression. RECIST 1.1 still standard but misses atypical patterns." } },
        { "id": "tbl-006-c4", "name": "response_category", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["iCR", "iPR", "iSD", "iUPD", "iCPD", "NE"], "weights": [5, 22, 30, 15, 20, 8], "_citation": "iRECIST: iUPD (unconfirmed PD) requires confirmation. iCPD (confirmed PD). iCR/iPR/iSD analogous to RECIST. Allows for pseudo-progression window." } },
        { "id": "tbl-006-c5", "name": "target_lesion_change_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": -100, "max": 80, "precision": 1 } },
        { "id": "tbl-006-c6", "name": "response_pattern", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["conventional_response", "delayed_response", "pseudo_progression", "hyperprogression", "mixed_response", "abscopal_effect", "conventional_progression"], "weights": [30, 10, 7, 5, 12, 2, 34], "_citation": "IO atypical patterns: Pseudo-progression ~5-10% (Chiou 2018). Hyperprogression ~5-10% (Champiat 2017). Mixed response ~10-15%. Abscopal rare ~1-2%. Delayed response ~10%." } },
        { "id": "tbl-006-c7", "name": "new_lesions", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["none", "equivocal", "unequivocal_new"], "weights": [60, 15, 25], "_citation": "iRECIST: New lesions in IO may be pseudo-progression. Requires confirmation 4-8 weeks later." } },
        { "id": "tbl-006-c8", "name": "assessment_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 420, "y": 400 }
    },
    {
      "id": "tbl-007",
      "name": "pseudoprogression_events",
      "columns": [
        { "id": "tbl-007-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-007-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-007-c3", "name": "assessment_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-006", "columnId": "tbl-006-c1" } },
        { "id": "tbl-007-c4", "name": "initial_increase_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 5, "max": 40, "precision": 1 } },
        { "id": "tbl-007-c5", "name": "subsequent_decrease_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": -60, "max": -5, "precision": 1 } },
        { "id": "tbl-007-c6", "name": "confirmation_outcome", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["confirmed_pseudoprogression", "true_progression", "mixed_inconclusive"], "weights": [40, 45, 15], "_citation": "Chiou 2018/Hodi 2018: Of patients with initial radiographic PD, ~40% are pseudo-PD (true in melanoma, lower in NSCLC ~15%). ~45% confirmed true PD." } },
        { "id": "tbl-007-c7", "name": "time_to_confirmation_weeks", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 4, "max": 16 } },
        { "id": "tbl-007-c8", "name": "treatment_continued", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["yes_beyond_progression", "no_switched_therapy", "clinical_deterioration_stopped"], "weights": [50, 35, 15], "_citation": "iRECIST: Treatment beyond PD allowed if clinically stable. ~50% continue IO through iUPD. ~35% switch." } },
        { "id": "tbl-007-c9", "name": "detection_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 3 } }
      ],
      "position": { "x": 740, "y": 400 }
    },
    {
      "id": "tbl-008",
      "name": "hyperprogression_events",
      "columns": [
        { "id": "tbl-008-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-008-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-008-c3", "name": "tgr_ratio", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 2.0, "max": 10.0, "precision": 1 } },
        { "id": "tbl-008-c4", "name": "tgkr_ratio", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 2.0, "max": 8.0, "precision": 1 } },
        { "id": "tbl-008-c5", "name": "ttf_weeks", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 2, "max": 8 } },
