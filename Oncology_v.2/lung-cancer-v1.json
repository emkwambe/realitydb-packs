{
  "tables": [
    {
      "id": "tbl-001",
      "name": "patients",
      "columns": [
        { "id": "tbl-001-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-001-c2", "name": "mrn", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "template", "options": { "template": "LC-{{rowIndex}}" } },
        { "id": "tbl-001-c3", "name": "full_name", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "full_name", "options": {} },
        { "id": "tbl-001-c4", "name": "date_of_birth", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 40, "maxYearsAgo": 85 } },
        { "id": "tbl-001-c5", "name": "sex", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["male", "female"], "weights": [54, 46], "_citation": "ACS 2024: Lung cancer slightly more common in males. Male 54%, Female 46% of new cases." } },
        { "id": "tbl-001-c6", "name": "smoking_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["current_smoker", "former_smoker", "never_smoker", "unknown"], "weights": [20, 45, 30, 5], "_citation": "SEER/ACS: ~15-20% current, ~45% former, ~25-30% never-smokers (rising in adenocarcinoma). Never-smoker NSCLC increasing." } },
        { "id": "tbl-001-c7", "name": "pack_years", "type": "integer", "isPK": false, "isFK": false, "nullable": true, "strategy": "integer", "options": { "min": 0, "max": 80 } },
        { "id": "tbl-001-c8", "name": "ecog_baseline", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["0", "1", "2", "3", "4"], "weights": [25, 40, 20, 10, 5], "_citation": "Clinical trials: ECOG 0-1 most common enrollment criteria. Real-world includes ECOG 2-3. ECOG 4 rare at presentation." } },
        { "id": "tbl-001-c9", "name": "created_at", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "tbl-002",
      "name": "mutation_panel",
      "columns": [
        { "id": "tbl-002-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-002-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-002-c3", "name": "testing_method", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["NGS_panel", "PCR", "FISH", "IHC", "liquid_biopsy"], "weights": [45, 20, 15, 10, 10], "_citation": "NCCN: NGS recommended as standard. PCR for targeted EGFR. FISH for ALK/ROS1. Liquid biopsy increasing." } },
        { "id": "tbl-002-c4", "name": "driver_mutation", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["KRAS", "EGFR", "ALK", "ROS1", "BRAF", "MET", "RET", "HER2", "NTRK", "none_detected"], "weights": [25, 20, 6, 2, 3, 4, 2, 2, 1, 35], "_citation": "PMC8085514: KRAS ~30%, EGFR ~15-48% (ethnicity). PMC12416486: ALK 7.9%, EGFR 24%, KRAS 19.7%, ROS1 2.2%, MET 4.7%, BRAF 3.7%. Averaged for US population." } },
        { "id": "tbl-002-c5", "name": "egfr_variant", "type": "enum", "isPK": false, "isFK": false, "nullable": true, "strategy": "enum", "options": { "values": ["exon_19_deletion", "exon_21_L858R", "exon_20_insertion", "T790M", "other_uncommon", "not_applicable"], "weights": [20, 21, 2, 1, 2, 54], "_citation": "Frontiers 2024: Among EGFR+ cases: exon 19 del 42.79%, L858R 45.97%. Scaled to full population where ~46% are EGFR-." } },
        { "id": "tbl-002-c6", "name": "kras_variant", "type": "enum", "isPK": false, "isFK": false, "nullable": true, "strategy": "enum", "options": { "values": ["G12C", "G12V", "G12D", "G13D", "other", "not_applicable"], "weights": [10, 5, 5, 3, 2, 75], "_citation": "KRAS G12C most common actionable (~40% of KRAS mutations). G12V ~20%, G12D ~15%. Only ~25% of patients are KRAS+." } },
        { "id": "tbl-002-c7", "name": "pd_l1_tps", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["negative_0", "low_1_49", "high_50_plus"], "weights": [45, 30, 25], "_citation": "EARLY-EGFR JTO 2024: PD-L1 >=1% in 35.6%. >=50% in ~25%. Negative ~45%." } },
        { "id": "tbl-002-c8", "name": "tmb_category", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["low", "intermediate", "high"], "weights": [50, 30, 20], "_citation": "FDA: TMB-High >=10 mut/Mb. ~20% of NSCLC are TMB-H. Foundation Medicine data." } },
        { "id": "tbl-002-c9", "name": "report_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
      "position": { "x": 420, "y": 100 }
    },
    {
      "id": "tbl-003",
      "name": "diagnoses",
      "columns": [
        { "id": "tbl-003-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-003-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-003-c3", "name": "icd10_code", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["C34.1", "C34.2", "C34.3", "C34.8", "C34.9"], "weights": [30, 15, 25, 10, 20], "_citation": "WHO ICD-10: C34.1 upper lobe most common (~30%). C34.3 lower lobe ~25%. C34.9 unspecified ~20%." } },
        { "id": "tbl-003-c4", "name": "histology", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["adenocarcinoma", "squamous_cell", "large_cell", "nsclc_nos", "adenosquamous"], "weights": [50, 30, 5, 10, 5], "_citation": "PMC8085514: NSCLC ~85% of lung cancers. Adenocarcinoma ~50%, squamous ~30%, large cell ~5%." } },
        { "id": "tbl-003-c5", "name": "tnm_stage", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["IA1", "IA2", "IA3", "IB", "IIA", "IIB", "IIIA", "IIIB", "IIIC", "IVA", "IVB"], "weights": [3, 4, 3, 8, 5, 7, 10, 8, 5, 30, 17], "_citation": "SEER: ~50% NSCLC diagnosed distant stage (IVA/IVB). Regional ~25% (II-III). Localized ~18% (I)." } },
        { "id": "tbl-003-c6", "name": "laterality", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["right", "left", "bilateral"], "weights": [55, 42, 3], "_citation": "SEER: Right lung slightly more common (~55%) due to 3 lobes vs 2 on left." } },
        { "id": "tbl-003-c7", "name": "diagnosis_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
      "position": { "x": 740, "y": 100 }
    },
    {
      "id": "tbl-004",
      "name": "systemic_therapy",
      "columns": [
        { "id": "tbl-004-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-004-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-004-c3", "name": "therapy_class", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["immunotherapy", "targeted_therapy", "chemotherapy", "chemo_immunotherapy", "combination_targeted"], "weights": [25, 20, 20, 25, 10], "_citation": "NCCN NSCLC v2.2025: IO+chemo most common 1L for non-driver. TKIs for EGFR/ALK. Chemo declining as monotherapy." } },
        { "id": "tbl-004-c4", "name": "regimen_name", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["pembrolizumab_mono", "pembrolizumab_carboplatin_pemetrexed", "nivolumab_ipilimumab", "atezolizumab", "osimertinib", "alectinib", "sotorasib", "carboplatin_paclitaxel", "docetaxel", "durvalumab", "other"], "weights": [12, 18, 8, 7, 10, 5, 4, 12, 6, 8, 10], "_citation": "NCCN: Pembro+carbo+pem most common 1L non-squamous. Osimertinib standard EGFR+. Alectinib standard ALK+. Sotorasib for KRAS G12C." } },
        { "id": "tbl-004-c5", "name": "line_of_therapy", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["first_line", "second_line", "third_line", "fourth_plus"], "weights": [45, 30, 15, 10], "_citation": "Clinical practice: Most patients receive 1L. ~60-70% progress to 2L. Fewer reach 3L+." } },
        { "id": "tbl-004-c6", "name": "best_response", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["complete_response", "partial_response", "stable_disease", "progressive_disease", "not_evaluable"], "weights": [5, 30, 35, 25, 5], "_citation": "RECIST v1.1: ICI monotherapy ORR ~20-35% in NSCLC. CR rare (~5%). SD common. PD ~25-30%." } },
        { "id": "tbl-004-c7", "name": "cycles_administered", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 35 } },
        { "id": "tbl-004-c8", "name": "start_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } },
        { "id": "tbl-004-c9", "name": "end_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": true, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 3 } },
        { "id": "tbl-004-c10", "name": "discontinuation_reason", "type": "enum", "isPK": false, "isFK": false, "nullable": true, "strategy": "enum", "options": { "values": ["completed_protocol", "progressive_disease", "adverse_event", "patient_choice", "death", "physician_decision", "other"], "weights": [20, 30, 15, 8, 10, 10, 7], "_citation": "Clinical trials: PD most common reason ~30%. AE ~15%. Completed protocol ~20%. Death ~10% in advanced." } }
      ],
      "position": { "x": 1060, "y": 100 }
    },
    {
      "id": "tbl-005",
      "name": "immunotherapy_sessions",
      "columns": [
        { "id": "tbl-005-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-005-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-005-c3", "name": "therapy_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-005-c4", "name": "cycle_number", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 35 } },
        { "id": "tbl-005-c5", "name": "cycle_outcome", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["completed_on_schedule", "delayed", "dose_reduced", "held", "discontinued"], "weights": [55, 15, 5, 15, 10], "_citation": "Clinical trials: ~55% IO cycles on schedule. ~15% delayed (AE resolution). ~10% discontinued." } },
        { "id": "tbl-005-c6", "name": "infusion_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } },
        { "id": "tbl-005-c7", "name": "infusion_duration_min", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 30, "max": 120 } }
      ],
