    },
    {
      "id": "tbl-006",
      "name": "adverse_events",
      "columns": [
        { "id": "tbl-006-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-006-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-006-c3", "name": "therapy_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-006-c4", "name": "event_term", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["fatigue", "nausea", "diarrhea", "rash", "pneumonitis", "hepatotoxicity", "thyroid_dysfunction", "colitis", "nephritis", "neuropathy", "anemia", "neutropenia"], "weights": [18, 10, 9, 8, 10, 6, 6, 5, 3, 8, 10, 7], "_citation": "PMC11757769: Fatigue most frequent (~20%). Pneumonitis higher in lung (~10%). PMC8144509 confirms. Heme toxicity with chemo." } },
        { "id": "tbl-006-c5", "name": "ctcae_grade", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["1", "2", "3", "4", "5"], "weights": [38, 30, 18, 6, 1], "_citation": "PMC8144509: Grade 3+ AEs 17.7% ICI monotherapy. Grade 5 ~1%. CTCAE v5.0." } },
        { "id": "tbl-006-c6", "name": "relatedness", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["related", "possibly_related", "unlikely_related", "unrelated"], "weights": [15, 30, 20, 35], "_citation": "ICH E2A: ~45% deemed related/possibly related. Unrelated most common single category." } },
        { "id": "tbl-006-c7", "name": "action_taken", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["none", "dose_interrupted", "dose_reduced", "treatment_discontinued", "supportive_medication", "hospitalization"], "weights": [30, 15, 10, 12, 20, 13], "_citation": "FDA guidance: Dose modifications in ~40% of IO patients. Discontinuation ~10-15%." } },
        { "id": "tbl-006-c8", "name": "onset_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 3 } },
        { "id": "tbl-006-c9", "name": "resolution_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["resolved", "resolving", "not_resolved", "fatal", "unknown"], "weights": [50, 15, 25, 2, 8], "_citation": "Clinical practice: Most AEs resolve (~50%). Chronic toxicities (neuropathy, endocrine) may not resolve." } }
      ],
      "position": { "x": 420, "y": 400 }
    },
    {
