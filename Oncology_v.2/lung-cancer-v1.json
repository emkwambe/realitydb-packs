      ],
      "position": { "x": 1060, "y": 400 }
    },
    {
      "id": "tbl-009",
      "name": "surgical_procedures",
      "columns": [
        { "id": "tbl-009-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-009-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-009-c3", "name": "procedure_type", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["lobectomy", "pneumonectomy", "wedge_resection", "segmentectomy", "sleeve_resection", "mediastinoscopy", "thoracoscopy_biopsy"], "weights": [35, 8, 20, 12, 5, 10, 10], "_citation": "NCCN: Lobectomy standard for resectable NSCLC (~35%). Wedge/segmentectomy for small tumors or poor function. Pneumonectomy declining." } },
        { "id": "tbl-009-c4", "name": "margin_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["R0_negative", "R1_microscopic", "R2_macroscopic"], "weights": [85, 10, 5], "_citation": "Surgical series: R0 ~85% in experienced centers. R1 ~10%. R2 ~5% (incomplete resection)." } },
        { "id": "tbl-009-c5", "name": "lymph_nodes_sampled", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 3, "max": 25 } },
        { "id": "tbl-009-c6", "name": "n_stage_pathologic", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["N0", "N1", "N2", "N3"], "weights": [45, 20, 25, 10], "_citation": "SEER: ~45% N0 at resection. N2 (mediastinal) ~25%. N3 rarely resected (~10% of surgical cases)." } },
        { "id": "tbl-009-c7", "name": "procedure_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
