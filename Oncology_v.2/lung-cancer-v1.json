        { "id": "tbl-007-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-007-c3", "name": "modality", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["ct_chest", "pet_ct", "brain_mri", "bone_scan", "ct_abd_pelvis"], "weights": [40, 25, 15, 10, 10], "_citation": "NCCN: CT chest standard restaging. PET-CT for initial staging and equivocal findings. Brain MRI for all Stage III-IV." } },
        { "id": "tbl-007-c4", "name": "recist_response", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["complete_response", "partial_response", "stable_disease", "progressive_disease", "pseudo_progression"], "weights": [5, 25, 35, 28, 7], "_citation": "RECIST v1.1/iRECIST: CR ~5%, PR ~25%, SD ~35%, PD ~28%. Pseudo-progression ~5-10% with IO." } },
        { "id": "tbl-007-c5", "name": "target_lesion_change_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": -100, "max": 80, "precision": 1 } },
        { "id": "tbl-007-c6", "name": "new_lesions", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["none", "equivocal", "unequivocal"], "weights": [65, 15, 20], "_citation": "RECIST: New lesions = PD. Equivocal requires confirmation. ~65% no new lesions at any scan." } },
        { "id": "tbl-007-c7", "name": "scan_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 740, "y": 400 }
    },
    {
      "id": "tbl-008",
      "name": "radiation_plans",
      "columns": [
        { "id": "tbl-008-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-008-c2", "name": "patient_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-008-c3", "name": "technique", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["IMRT", "SBRT", "3D_conformal", "proton_therapy", "VMAT"], "weights": [30, 25, 20, 5, 20], "_citation": "NCCN: IMRT and VMAT standard for locally advanced. SBRT for early-stage inoperable. Proton therapy emerging." } },
        { "id": "tbl-008-c4", "name": "intent", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["definitive", "adjuvant", "neoadjuvant", "palliative", "consolidation"], "weights": [30, 10, 5, 35, 20], "_citation": "NCCN: Palliative RT common in Stage IV (bone/brain mets ~35%). Definitive for Stage III with concurrent chemo. Consolidation with durvalumab." } },
        { "id": "tbl-008-c5", "name": "total_dose_gy", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 20, "max": 70, "precision": 1 } },
        { "id": "tbl-008-c6", "name": "fractions", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 35 } },
