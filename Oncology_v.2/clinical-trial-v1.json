{
  "tables": [
    {
      "id": "tbl-001",
      "name": "trials",
      "columns": [
        { "id": "tbl-001-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-001-c2", "name": "nct_id", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "template", "options": { "template": "NCT{{rowIndex}}" } },
        { "id": "tbl-001-c3", "name": "phase", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["Phase_I", "Phase_I_II", "Phase_II", "Phase_II_III", "Phase_III"], "weights": [15, 10, 30, 10, 35], "_citation": "ClinicalTrials.gov: Phase III ~35% of oncology trials. Phase II ~30%. Phase I ~15%. Combined phases ~20%. FDA guidance." } },
        { "id": "tbl-001-c4", "name": "study_design", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["randomized_controlled", "single_arm", "dose_escalation", "basket", "umbrella", "platform"], "weights": [40, 25, 15, 8, 7, 5], "_citation": "ASCO/FDA: RCTs ~40% of oncology trials. Single-arm common in Phase II (~25%). Dose escalation in Phase I (~15%). Adaptive designs emerging." } },
        { "id": "tbl-001-c5", "name": "randomization_ratio", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["1:1", "2:1", "3:1", "not_randomized"], "weights": [35, 20, 5, 40], "_citation": "ICH E9: 1:1 standard for Phase III RCTs. 2:1 favoring experimental common. Not randomized for single-arm/dose-escalation." } },
        { "id": "tbl-001-c6", "name": "primary_endpoint", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["overall_survival", "progression_free_survival", "objective_response_rate", "dose_limiting_toxicity", "disease_free_survival", "pathologic_complete_response"], "weights": [25, 30, 20, 10, 8, 7], "_citation": "FDA oncology guidance: PFS most common primary endpoint (~30%). OS gold standard (~25%). ORR for accelerated approval. DLT for Phase I." } },
        { "id": "tbl-001-c7", "name": "tumor_type", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["NSCLC", "breast", "colorectal", "melanoma", "renal_cell", "urothelial", "head_neck", "gastric", "hepatocellular", "pan_tumor"], "weights": [20, 15, 12, 10, 8, 7, 6, 6, 6, 10], "_citation": "ClinicalTrials.gov: NSCLC most common tumor type in IO/targeted trials. Breast second. Pan-tumor for TMB-H/MSI-H." } },
        { "id": "tbl-001-c8", "name": "sponsor_type", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["industry", "academic", "cooperative_group", "nci_funded", "investigator_initiated"], "weights": [45, 20, 15, 10, 10], "_citation": "ClinicalTrials.gov: Industry sponsors ~45% of oncology trials. Academic ~20%. NCI/cooperative groups ~25%." } },
        { "id": "tbl-001-c9", "name": "start_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } },
        { "id": "tbl-001-c10", "name": "status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["recruiting", "active_not_recruiting", "completed", "terminated", "suspended", "withdrawn"], "weights": [30, 20, 25, 12, 8, 5], "_citation": "ClinicalTrials.gov: ~30% actively recruiting at any time. ~25% completed. ~12% terminated (futility/safety)." } }
      ],
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "tbl-002",
      "name": "trial_arms",
      "columns": [
        { "id": "tbl-002-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-002-c2", "name": "trial_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-002-c3", "name": "arm_name", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["experimental", "active_comparator", "placebo_comparator", "dose_level_1", "dose_level_2", "dose_level_3", "combination"], "weights": [30, 20, 15, 8, 8, 7, 12], "_citation": "ICH E9: Experimental arm always present. Comparator in RCTs. Dose levels in Phase I 3+3 design." } },
        { "id": "tbl-002-c4", "name": "arm_type", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["experimental", "active_control", "placebo", "dose_finding"], "weights": [40, 25, 15, 20], "_citation": "FDA guidance: Experimental arm standard. Active control preferred over placebo in oncology (ethical)." } },
        { "id": "tbl-002-c5", "name": "regimen_description", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["anti_PD1_mono", "anti_PD1_chemo", "anti_PDL1_mono", "TKI_mono", "TKI_chemo", "anti_CTLA4_anti_PD1", "ADC_mono", "bispecific", "chemo_standard", "placebo_chemo"], "weights": [15, 18, 8, 12, 8, 10, 8, 5, 10, 6], "_citation": "NCCN/ASCO: IO+chemo most common experimental regimen. TKI for driver+ populations. ADCs and bispecifics emerging." } },
        { "id": "tbl-002-c6", "name": "target_enrollment", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 20, "max": 800 } }
      ],
      "position": { "x": 420, "y": 100 }
    },
    {
      "id": "tbl-003",
      "name": "sites",
      "columns": [
        { "id": "tbl-003-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-003-c2", "name": "trial_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-003-c3", "name": "site_name", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "company_name", "options": {} },
        { "id": "tbl-003-c4", "name": "country", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["US", "UK", "Germany", "France", "Japan", "China", "Australia", "Canada", "South_Korea", "Brazil"], "weights": [35, 10, 10, 8, 8, 8, 5, 6, 5, 5], "_citation": "ClinicalTrials.gov: US hosts ~35% of oncology trial sites. Europe ~28%. Asia-Pacific ~20%." } },
        { "id": "tbl-003-c5", "name": "site_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["active", "closed", "not_yet_recruiting", "suspended"], "weights": [50, 25, 15, 10], "_citation": "Clinical operations: ~50% sites active at any snapshot. ~25% closed enrollment." } },
        { "id": "tbl-003-c6", "name": "irb_approval_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 5 } }
      ],
      "position": { "x": 740, "y": 100 }
    },
    {
      "id": "tbl-004",
      "name": "subjects",
      "columns": [
        { "id": "tbl-004-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-004-c2", "name": "trial_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-001", "columnId": "tbl-001-c1" } },
        { "id": "tbl-004-c3", "name": "arm_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-002", "columnId": "tbl-002-c1" } },
        { "id": "tbl-004-c4", "name": "site_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-003", "columnId": "tbl-003-c1" } },
        { "id": "tbl-004-c5", "name": "subject_id_masked", "type": "string", "isPK": false, "isFK": false, "nullable": false, "strategy": "template", "options": { "template": "SUBJ-{{rowIndex}}" } },
        { "id": "tbl-004-c6", "name": "age_at_enrollment", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 18, "max": 85 } },
        { "id": "tbl-004-c7", "name": "sex", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["male", "female"], "weights": [52, 48], "_citation": "FDA 2020 Drug Trials Snapshot: ~48% female enrollment in oncology trials. Improving from historically lower." } },
        { "id": "tbl-004-c8", "name": "ecog_at_baseline", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["0", "1", "2"], "weights": [35, 50, 15], "_citation": "Most trials require ECOG 0-1. ECOG 2 allowed in some. ECOG 0 ~35%, ECOG 1 ~50% in trial populations." } },
        { "id": "tbl-004-c9", "name": "prior_lines_therapy", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["0", "1", "2", "3_plus"], "weights": [30, 35, 20, 15], "_citation": "Clinical trials: Treatment-naive ~30% (1L trials). 1 prior line ~35% (2L). 2+ prior ~35% (later lines)." } },
        { "id": "tbl-004-c10", "name": "stratification_factor_1", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["PD-L1_high", "PD-L1_low", "PD-L1_negative"], "weights": [25, 30, 45], "_citation": "Common stratification: PD-L1 TPS. High (>=50%) ~25%, Low (1-49%) ~30%, Negative (<1%) ~45%." } },
        { "id": "tbl-004-c11", "name": "stratification_factor_2", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["squamous", "non_squamous", "other_histology"], "weights": [30, 60, 10], "_citation": "NSCLC trials commonly stratify by histology. Non-squamous ~60%, Squamous ~30%." } },
        { "id": "tbl-004-c12", "name": "enrollment_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } },
        { "id": "tbl-004-c13", "name": "informed_consent_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 1060, "y": 100 }
    },
    {
      "id": "tbl-005",
      "name": "dosing_records",
      "columns": [
        { "id": "tbl-005-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-005-c2", "name": "subject_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-005-c3", "name": "cycle_number", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 1, "max": 35 } },
        { "id": "tbl-005-c4", "name": "dose_level_mg", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 50, "max": 1200, "precision": 0 } },
        { "id": "tbl-005-c5", "name": "dose_modification", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["full_dose", "reduced_level_1", "reduced_level_2", "held", "discontinued"], "weights": [60, 15, 5, 12, 8], "_citation": "Clinical trials: ~60% receive full dose. Dose reductions in ~20%. Held ~12% per cycle. Discontinued ~8%." } },
        { "id": "tbl-005-c6", "name": "dose_delay_days", "type": "integer", "isPK": false, "isFK": false, "nullable": false, "strategy": "integer", "options": { "min": 0, "max": 21 } },
        { "id": "tbl-005-c7", "name": "dlt_event", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["no", "yes"], "weights": [85, 15], "_citation": "Phase I: DLT rate ~15-30% at MTD. 3+3 design targets 33% DLT rate at MTD. Average across doses ~15%." } },
        { "id": "tbl-005-c8", "name": "administration_route", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["IV_infusion", "oral", "subcutaneous", "intrathecal"], "weights": [50, 35, 10, 5], "_citation": "Oncology: IV infusion standard for mAbs/chemo (~50%). Oral TKIs increasing (~35%). SC formulations emerging." } },
        { "id": "tbl-005-c9", "name": "administration_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 100, "y": 400 }
    },
    {
      "id": "tbl-006",
      "name": "adverse_events",
      "columns": [
        { "id": "tbl-006-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-006-c2", "name": "subject_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-006-c3", "name": "ae_term", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["fatigue", "nausea", "diarrhea", "rash", "pneumonitis", "hepatotoxicity", "neutropenia", "anemia", "thrombocytopenia", "neuropathy", "colitis", "thyroid_dysfunction", "infusion_reaction", "arthralgia", "vomiting"], "weights": [14, 10, 8, 7, 6, 5, 8, 7, 4, 5, 4, 5, 4, 4, 3], "_citation": "PMC8144509: Fatigue most common (~14%). Heme toxicities with chemo. irAEs with IO. PMC11757769 confirms." } },
        { "id": "tbl-006-c4", "name": "ctcae_grade", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["1", "2", "3", "4", "5"], "weights": [35, 30, 20, 10, 2], "_citation": "PMC8144509: Grade 3+ in 17.7% ICI mono, 54.3% combination. Grade 5 (death) ~1-2%. CTCAE v5.0. Weighted for mixed regimens." } },
        { "id": "tbl-006-c5", "name": "causality", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["related", "possibly_related", "unlikely_related", "unrelated", "not_assessable"], "weights": [15, 25, 20, 35, 5], "_citation": "ICH E2A: ~40% deemed related/possibly related. Unrelated most common single category." } },
        { "id": "tbl-006-c6", "name": "serious", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["yes", "no"], "weights": [25, 75], "_citation": "ICH E2A: SAE ~25% in oncology trials. Serious = hospitalization, life-threatening, death, disability." } },
        { "id": "tbl-006-c7", "name": "action_taken", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["none", "dose_reduced", "dose_interrupted", "drug_withdrawn", "concomitant_medication", "hospitalization"], "weights": [30, 12, 15, 10, 20, 13], "_citation": "FDA guidance: ~40% require dose modification. Withdrawal ~10%. Concomitant meds (steroids, antiemetics) ~20%." } },
        { "id": "tbl-006-c8", "name": "outcome", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["recovered", "recovering", "not_recovered", "recovered_with_sequelae", "fatal", "unknown"], "weights": [45, 15, 20, 8, 2, 10], "_citation": "Clinical trials: ~45% recovered. Chronic AEs ~20% not recovered. Fatal ~2%." } },
        { "id": "tbl-006-c9", "name": "onset_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 3 } },
        { "id": "tbl-006-c10", "name": "resolution_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": true, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 2 } }
      ],
      "position": { "x": 420, "y": 400 }
    },
    {
      "id": "tbl-007",
      "name": "efficacy_assessments",
      "columns": [
        { "id": "tbl-007-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-007-c2", "name": "subject_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-007-c3", "name": "assessment_timepoint", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["week_6", "week_9", "week_12", "week_18", "week_24", "week_36", "week_48", "end_of_treatment"], "weights": [15, 15, 20, 15, 12, 8, 5, 10], "_citation": "RECIST: Imaging typically Q6-12 weeks. Most common at week 9 and 12. Later assessments less frequent." } },
        { "id": "tbl-007-c4", "name": "recist_response", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["CR", "PR", "SD", "PD", "NE"], "weights": [5, 25, 35, 30, 5], "_citation": "RECIST v1.1: ORR (CR+PR) 20-35% for IO. CR rare (~5%). SD most common best response. PD ~30%." } },
        { "id": "tbl-007-c5", "name": "target_lesion_sum_mm", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 10, "max": 200, "precision": 1 } },
        { "id": "tbl-007-c6", "name": "change_from_baseline_pct", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": -100, "max": 80, "precision": 1 } },
        { "id": "tbl-007-c7", "name": "new_lesions", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["no", "equivocal", "yes"], "weights": [65, 10, 25], "_citation": "RECIST: New unequivocal lesions = PD. ~25% show new lesions during treatment course." } },
        { "id": "tbl-007-c8", "name": "confirmation_status", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["confirmed", "unconfirmed", "pending"], "weights": [60, 25, 15], "_citation": "RECIST: Responses require confirmation at next assessment (>=4 weeks). ~60% confirmed." } },
        { "id": "tbl-007-c9", "name": "assessment_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 4 } }
      ],
      "position": { "x": 740, "y": 400 }
    },
    {
      "id": "tbl-008",
      "name": "survival",
      "columns": [
        { "id": "tbl-008-c1", "name": "id", "type": "uuid", "isPK": true, "isFK": false, "nullable": false, "strategy": "uuid", "options": {} },
        { "id": "tbl-008-c2", "name": "subject_id", "type": "uuid", "isPK": false, "isFK": true, "nullable": false, "strategy": "uuid", "options": {}, "fkTarget": { "tableId": "tbl-004", "columnId": "tbl-004-c1" } },
        { "id": "tbl-008-c3", "name": "pfs_months", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 0.5, "max": 36, "precision": 1 } },
        { "id": "tbl-008-c4", "name": "pfs_event", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["progressed", "censored_alive", "censored_lost", "death"], "weights": [50, 30, 10, 10], "_citation": "KM analysis: ~50% have PFS event (progression). ~30% censored alive (still on treatment). ~10% death without progression." } },
        { "id": "tbl-008-c5", "name": "os_months", "type": "decimal", "isPK": false, "isFK": false, "nullable": false, "strategy": "number", "options": { "min": 1, "max": 60, "precision": 1 } },
        { "id": "tbl-008-c6", "name": "os_event", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["death", "censored_alive", "censored_lost"], "weights": [40, 45, 15], "_citation": "KM analysis: ~40% death event in advanced NSCLC at 2-3 year follow-up. ~45% censored alive. ~15% lost." } },
        { "id": "tbl-008-c7", "name": "duration_of_response_months", "type": "decimal", "isPK": false, "isFK": false, "nullable": true, "strategy": "number", "options": { "min": 1, "max": 30, "precision": 1 } },
        { "id": "tbl-008-c8", "name": "best_overall_response", "type": "enum", "isPK": false, "isFK": false, "nullable": false, "strategy": "enum", "options": { "values": ["CR", "PR", "SD", "PD", "NE"], "weights": [5, 28, 32, 30, 5], "_citation": "RECIST: Best overall response across all assessments. CR ~5%, PR ~28%, SD ~32%, PD ~30%. NE ~5%." } },
        { "id": "tbl-008-c9", "name": "last_followup_date", "type": "timestamp", "isPK": false, "isFK": false, "nullable": false, "strategy": "past_date", "options": { "minYearsAgo": 0, "maxYearsAgo": 1 } }
      ],
      "position": { "x": 1060, "y": 400 }
    },
    {
      "id": "tbl-009",
      "name": "lab_results",
      "columns": [
