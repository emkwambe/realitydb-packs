              10,
              35
            ]
          }
        },
        "study_design": {
          "strategy": "enum",
          "options": {
            "values": [
              "randomized_controlled",
              "single_arm",
              "dose_escalation",
              "basket",
              "umbrella",
              "platform"
            ],
            "weights": [
              40,
              25,
              15,
              8,
              7,
              5
            ]
          }
        },
        "randomization_ratio": {
          "strategy": "enum",
          "options": {
            "values": [
              "1:1",
              "2:1",
              "3:1",
