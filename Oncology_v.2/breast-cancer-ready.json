{
  "name": "studio-export",
  "version": "1.0.0",
  "description": "Converted from Studio v4 by realitydb doctor",
  "tables": {
    "patients": {
      "match": "patients",
      "columns": {
        "id": {
          "strategy": "uuid"
        },
        "mrn": {
          "strategy": "template",
          "options": {
            "template": "MRN-{{rowIndex}}"
          }
        },
        "full_name": {
          "strategy": "full_name"
        },
        "date_of_birth": {
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 30,
            "maxYearsAgo": 85
          }
        },
        "sex": {
          "strategy": "enum",
          "options": {
            "values": [
              "female",
              "male"
            ],
            "weights": [
              99,
              1
            ]
          }
        },
        "race_ethnicity": {
          "strategy": "enum",
          "options": {
            "values": [
              "non_hispanic_white",
              "non_hispanic_black",
              "hispanic",
              "asian_pacific_islander",
              "american_indian",
              "other"
            ],
            "weights": [
              60,
              14,
              15,
              7,
              1,
              3
            ]
          }
        },
        "menopausal_status": {
          "strategy": "enum",
          "options": {
            "values": [
              "premenopausal",
              "perimenopausal",
              "postmenopausal"
            ],
            "weights": [
              25,
              10,
              65
            ]
          }
        },
        "family_history": {
          "strategy": "enum",
          "options": {
            "values": [
              "none",
              "first_degree",
              "second_degree",
              "brca1",
              "brca2",
              "other_genetic"
            ],
            "weights": [
              65,
              15,
              10,
              3,
              3,
              4
            ]
          }
        },
        "created_at": {
          "strategy": "past_date",
          "options": {
            "minYearsAgo": 0,
            "maxYearsAgo": 5
          }
        }
      }
    },
